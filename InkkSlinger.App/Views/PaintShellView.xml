<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.PaintShellView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             Padding="0">
  <AdornerDecorator x:Name="CanvasAdornerRoot">
    <ScrollViewer x:Name="DrawingScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <Canvas Width="2400" Height="1200">
        <Border x:Name="SelectedShape"
                Width="220"
                Height="140"
                BorderThickness="1"
                Canvas.Left="640"
                Canvas.Top="300" />
      </Canvas>
    </ScrollViewer>
  </AdornerDecorator>
</UserControl>




