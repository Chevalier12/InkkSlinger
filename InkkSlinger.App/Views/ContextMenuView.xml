<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ContextMenuView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid x:Name="RootHost">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: ContextMenu" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="ContextMenu can be attached to any UIElement, opened programmatically, positioned relative to a target, and kept open for multi-step workflows. Right-click the blue Design surface card, the Focused inspector target button, or the purple Review dock card below. The launch buttons open the same behaviors programmatically." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Attached targets" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="These three targets use the attached ContextMenu property. Right-click the blue Design surface card, right-click the Focused inspector target button, or right-click the purple Review dock card in the right column. The button target can also be focused and opened with Shift+F10 or the Apps key." />

                  <Border x:Name="SurfaceTarget"
                          Background="#1B2A3A"
                          BorderBrush="#5B88B8"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <Label Content="Design surface card" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"
                                 Text="Right-click to open a richer asset menu with nested recent files, diagnostics, and navigator actions." />
                    </StackPanel>
                  </Border>

                  <Button x:Name="InspectorTarget"
                          Content="Focused inspector target"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,8" />

                  <TextBlock x:Name="AttachedHintLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Right-click targets: blue Design surface card, Focused inspector target button, and purple Review dock card." />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Programmatic placement" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Programmatic open is useful for custom affordances. The first button opens below an anchor using PlacementTarget and offsets. The second opens at absolute coordinates over the timeline preview." />

                  <Border x:Name="PlacementAnchor"
                          Background="#23311F"
                          BorderBrush="#6A9D58"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,8">
                    <StackPanel>
                      <Label Content="Placement anchor" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"
                                 Text="Anchored menus resolve from this element when Placement is Bottom." />
                    </StackPanel>
                  </Border>

                  <Border x:Name="AbsoluteHotspot"
                          Background="#30261A"
                          BorderBrush="#D28C3B"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <Label Content="Timeline hotspot" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"
                                 Text="Absolute open drops the menu into this area without relying on the target's arranged edge." />
                    </StackPanel>
                  </Border>

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="OpenAnchoredMenuButton" Content="Open below anchor" Margin="0,0,8,8" />
                    <Button x:Name="OpenAbsoluteMenuButton" Content="Open at hotspot" Margin="0,0,8,8" />
                    <Button x:Name="CloseMenusButton" Content="Close menus" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="PlacementStateLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Last placement: none" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Persistent review menu" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="This menu sets StaysOpen=True so several actions can be applied in sequence before dismissal. Right-click the dock or launch it from the button." />

                  <Border x:Name="PersistentTarget"
                          Background="#221C31"
                          BorderBrush="#8B6DB8"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <Label Content="Review dock" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"
                                 Text="Use this to stage multiple density and overlay changes without dismissing the menu after each click." />
                    </StackPanel>
                  </Border>

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="OpenPersistentMenuButton" Content="Open persistent menu" Margin="0,0,8,8" />
                    <Button x:Name="ClosePersistentMenuButton" Content="Dismiss persistent menu" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="PersistentStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Persistent menu state: closed" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Lifecycle telemetry" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Opened and Closed events, item invocation, and the target that launched the menu are all surfaced below so the demo doubles as a behavior probe." />

                  <TextBlock x:Name="OpenedCountLabel" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Opened: 0" />
                  <TextBlock x:Name="ClosedCountLabel" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Closed: 0" />
                  <TextBlock x:Name="LastMenuLabel" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Last menu: none" />
                  <TextBlock x:Name="LastTargetLabel" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Last target: none" />
                  <TextBlock x:Name="LastActionLabel" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Last action: none" />
                  <TextBlock x:Name="LifecycleStatusLabel" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Text="Lifecycle: idle" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Demo coverage" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Text="This page covers attached menus, nested submenus, explicit InputGestureText labels, PlacementTarget and offset positioning, absolute open, StaysOpen, and lifecycle events in a single catalog surface." />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






