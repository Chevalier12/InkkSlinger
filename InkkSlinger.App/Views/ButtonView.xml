<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ButtonView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: Button" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="Button raises a bubbling Click routed event and tracks IsMouseOver and IsPressed internally. Hover over and click buttons below to observe visual-state transitions." />

          <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Left column: states and styling -->
          <StackPanel Grid.Column="0">

            <!-- Visual states -->
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14"
                    Margin="0,0,0,10">
              <StackPanel>
                <Label Content="Visual states" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Default style applies trigger-based background changes for Normal, MouseOver, Pressed, and Disabled states." />

                <WrapPanel>
                  <Button Content="Normal" Margin="0,0,8,8" />
                  <Button Content="Disabled" IsEnabled="False" Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Custom styling -->
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14"
                    Margin="0,0,0,10">
              <StackPanel>
                <Label Content="Custom styling" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Background, BorderBrush, BorderThickness, Foreground, and Padding are all settable per-instance." />

                <WrapPanel>
                  <Button Content="Accent"
                          Background="{StaticResource OrangePrimaryBrush}"
                          BorderBrush="{StaticResource OrangeDarkBrush}"
                          Foreground="{StaticResource DarkBgBrush}"
                          Margin="0,0,8,8" />
                  <Button Content="Danger"
                          Background="{StaticResource DangerRedBrush}"
                          BorderBrush="{StaticResource DangerRedBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,0,0,8" />
                </WrapPanel>

                <WrapPanel>
                  <Button Content="Flat / no border"
                          Background="{StaticResource DarkBgBrush}"
                          BorderThickness="0"
                          Foreground="{StaticResource OrangePrimaryBrush}"
                          Margin="0,0,8,8" />
                  <Button Content="Thick border"
                          BorderBrush="{StaticResource OrangeSubtleBrush}"
                          BorderThickness="2"
                          Padding="14,10,14,10"
                          Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Text wrapping -->
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14">
              <StackPanel>
                <Label Content="Text wrapping" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Wrapped button labels should be hosted in a TextBlock so they reflow inside the button's available width." />

                <Button Content="Short label" Margin="0,6,0,8" />
                <Button MaxWidth="320"
                        HorizontalAlignment="Stretch">
                  <TextBlock Text="This label is intentionally long and wraps when the button is constrained to the preview pane"
                             TextWrapping="Wrap" />
                </Button>
              </StackPanel>
            </Border>

          </StackPanel>

          <!-- Right column: click feedback -->
          <StackPanel Grid.Column="2">

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14"
                    Margin="0,0,0,10">
              <StackPanel>
                <Label Content="Click event" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Button raises a bubbling RoutedEvent. The counter below is incremented by the Click handler attached in code-behind." />

                <Button x:Name="CountedButton" Content="Click me" Margin="0,6,0,10" />
                <TextBlock x:Name="ClickCountLabel"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Clicks: 0" />
              </StackPanel>
            </Border>

            <!-- Padding variation -->
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14"
                    Margin="0,0,0,10">
              <StackPanel>
                <Label Content="Padding" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Default Padding is (10,6,10,6). Compact and spacious variants show the range." />

                <WrapPanel Margin="0,6,0,0">
                  <Button Content="Compact" Padding="4,2,4,2" Margin="0,0,8,8" />
                  <Button Content="Default" Margin="0,0,8,8" />
                  <Button Content="Spacious" Padding="20,12,20,12" Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Alignment and stretch -->
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="14">
              <StackPanel>
                <Label Content="Alignment" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="HorizontalAlignment controls whether the button sizes to content or fills its container." />

                <Button Content="Left-aligned"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6" />
                <Button Content="Centered"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,6" />
                <Button Content="Stretched"
                        HorizontalAlignment="Stretch" />
              </StackPanel>
            </Border>

          </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
