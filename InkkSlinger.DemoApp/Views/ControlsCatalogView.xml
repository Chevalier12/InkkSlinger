<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ControlsCatalogView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#1E1E1E"
             Padding="8">
  <Grid x:Name="ControlsCatalogRootGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0"
            Background="#2A2A2A"
            BorderBrush="#3F3F3F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,8,0">
      <Grid x:Name="ControlsCatalogSidebarGrid">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Content="Control Views"
               Foreground="#FF8C00"
               FontWeight="SemiBold"
               FontSize="15"
               Margin="2,0,0,4" />

        <!-- Accent divider -->
        <Border Grid.Row="1"
                Height="2"
                Background="#FF8C00"
                CornerRadius="1"
                Margin="0,0,0,10"
                Opacity="0.5" />

        <ScrollViewer x:Name="CatalogSidebarScrollViewer"
                      Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel x:Name="ControlButtonsHost" />
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Main Content -->
        <Grid x:Name="ControlsCatalogMainContentGrid"
          Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Header bar -->
      <Border Grid.Row="0"
              Background="#333333"
              BorderBrush="#3F3F3F"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12,8"
              Margin="0,0,0,8">
        <Label x:Name="SelectedControlLabel"
               Foreground="#F0F0F0"
               FontSize="14"
               Content="Selected:" />
      </Border>

      <!-- Preview area -->
      <Border Grid.Row="1"
              Background="#242424"
              BorderBrush="#3F3F3F"
              BorderThickness="1"
              CornerRadius="8"
              Padding="8">
        <ContentControl x:Name="PreviewHost" />
      </Border>
    </Grid>
  </Grid>
</UserControl>




