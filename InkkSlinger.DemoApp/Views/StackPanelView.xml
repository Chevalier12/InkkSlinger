<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.StackPanelView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Control Demo: StackPanel Workbench"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
          <TextBlock Text="A WPF-style StackPanel demo for orientation, child order, cross-axis alignment, collapsed children, nested composition, and ScrollViewer-hosted overflow."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#8FD3FF"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="Flow • Order • Overflow"
                     Foreground="#D9F3FF"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="StackPanelViewContentGrid"
          Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="0" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Border x:Name="StackPanelViewBodyBorder"
              Grid.Row="0"
              Grid.Column="0"
              Background="{StaticResource DarkSurfaceBrush}"
              BorderBrush="{StaticResource DarkBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,10,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Live layout workbench"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="This preview hosts a real StackPanel inside a ScrollViewer so the control keeps doing what WPF developers expect: one-dimensional layout, declaration-ordered children, and overflow handled by the scrolling owner."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,12">
                  <StackPanel>
                    <WrapPanel Margin="0,0,0,10">
                      <ComboBox x:Name="OrientationComboBox"
                                Width="154"
                                Margin="0,0,10,8"
                                SelectionChanged="OnWorkbenchOptionChanged" />
                      <ComboBox x:Name="CrossAxisAlignmentComboBox"
                                Width="170"
                                Margin="0,0,10,8"
                                SelectionChanged="OnWorkbenchOptionChanged" />
                      <CheckBox x:Name="TightViewportCheckBox"
                                Content="Tight viewport"
                                IsChecked="True"
                                Margin="0,0,12,8"
                                Checked="OnWorkbenchToggleChanged"
                                Unchecked="OnWorkbenchToggleChanged" />
                      <CheckBox x:Name="CollapseSecondaryCardCheckBox"
                                Content="Collapse secondary card"
                                Margin="0,0,12,8"
                                Checked="OnWorkbenchToggleChanged"
                                Unchecked="OnWorkbenchToggleChanged" />
                      <CheckBox x:Name="EmphasizeHeroCardCheckBox"
                                Content="Emphasize hero card"
                                Margin="0,0,0,8"
                                Checked="OnWorkbenchToggleChanged"
                                Unchecked="OnWorkbenchToggleChanged" />
                    </WrapPanel>

                    <TextBlock Text="Use the buttons below to mutate the child collection the same way a WPF view might add, remove, or reorder chrome sections at runtime."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,10,0,0">
                      <Button x:Name="AddChildButton"
                              Content="Add child"
                            Margin="0,0,8,8"
                            Click="OnAddChildClicked" />
                      <Button x:Name="RemoveLastButton"
                              Content="Remove last"
                            Margin="0,0,8,8"
                            Click="OnRemoveLastClicked" />
                      <Button x:Name="MoveFirstToEndButton"
                              Content="Move first to end"
                            Margin="0,0,8,8"
                            Click="OnMoveFirstToEndClicked" />
                      <Button x:Name="ResetStackButton"
                              Content="Reset stack"
                            Margin="0,0,0,8"
                            Click="OnResetStackClicked" />
                    </WrapPanel>
                  </StackPanel>
                </Border>

                <Border x:Name="WorkbenchStageBorder"
                        Background="#0F151A"
                        BorderBrush="#355165"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Height="296"
                        ClipToBounds="True">
                  <ScrollViewer x:Name="WorkbenchScrollViewer"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                Background="#0F151A"
                                BorderBrush="#355165"
                                BorderThickness="0">
                    <StackPanel x:Name="WorkbenchPanel"
                                Orientation="Vertical" />
                  </ScrollViewer>
                </Border>

                <Border Background="#101922"
                        BorderBrush="#3A576C"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="WorkbenchNarrativeText"
                               Foreground="#E2F0F7"
                               Text="Narrative"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkbenchMutationText"
                               Foreground="#A8C7D8"
                               Text="Mutation summary"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel>
                <TextBlock Text="WPF-style composition gallery"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="These static examples show the common ways StackPanel gets used in real views: inspector columns, horizontal command bars, and nested detail cards where order matters more than cell coordinates."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,3,0,12" />

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="0"
                          Background="#11181F"
                          BorderBrush="#355061"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="12"
                          Margin="0,0,0,12">
                    <StackPanel>
                      <TextBlock Text="Inspector column"
                                 Foreground="#E3F1F8"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="Classic vertical StackPanel usage for settings and labels."
                                 Foreground="#AFC9D8"
                                 TextWrapping="Wrap"
                                 Margin="0,4,0,10" />

                      <StackPanel>
                        <TextBlock Text="Profile" Foreground="#D7EAF5" FontWeight="SemiBold" />
                        <Border Background="#17222B" BorderBrush="#446273" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,4,0,8">
                          <TextBlock Text="Even simple forms usually rely on a vertical stack because declaration order is the behavior." Foreground="#B8CFDB" TextWrapping="Wrap" />
                        </Border>
                        <CheckBox Content="Receive release notes" IsChecked="True" Margin="0,0,0,8" />
                        <CheckBox Content="Pin diagnostics rail" Margin="0,0,0,8" />
                        <Button Content="Save settings" HorizontalAlignment="Left" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <StackPanel Grid.Column="2">
                    <Border Background="#11181F"
                            BorderBrush="#355061"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                      <StackPanel>
                        <TextBlock Text="Horizontal command strip"
                                   Foreground="#E3F1F8"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Switch orientation and the same panel type becomes a toolbar-like rail." 
                                   Foreground="#AFC9D8"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,10" />

                        <StackPanel Orientation="Horizontal">
                          <Button Content="Back" Margin="0,0,8,0" />
                          <Button Content="Approve" Margin="0,0,8,0" />
                          <Button Content="Queue" Margin="0,0,8,0" />
                          <Border Background="#1C3140" BorderBrush="#587A8F" BorderThickness="1" CornerRadius="12" Padding="10,4">
                            <TextBlock Text="4 pending" Foreground="#DDF1FB" TextWrapping="Wrap" />
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <Border Background="#11181F"
                            BorderBrush="#355061"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                      <StackPanel>
                        <TextBlock Text="Nested detail card"
                                   Foreground="#E3F1F8"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Outer vertical stack for sections, inner horizontal stack for badges and actions." 
                                   Foreground="#AFC9D8"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,10" />

                        <Border Background="#18242E"
                                BorderBrush="#48687B"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                          <StackPanel>
                            <TextBlock Text="StackPanel is often the default view-level layout because it keeps intent obvious." 
                                       Foreground="#E3F1F8"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Use Grid when you need two-dimensional relationships. Use StackPanel when flow order is the main rule." 
                                       Foreground="#B7CDDA"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,10" />
                            <StackPanel Orientation="Horizontal">
                              <Border Background="#284252" BorderBrush="#6A95AA" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="Order-driven" Foreground="#E6F3FA" TextWrapping="Wrap" />
                              </Border>
                              <Border Background="#2B3D2A" BorderBrush="#6D9365" BorderThickness="1" CornerRadius="12" Padding="10,4">
                                <TextBlock Text="Nested easily" Foreground="#E8F5E3" TextWrapping="Wrap" />
                              </Border>
                            </StackPanel>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <ScrollViewer x:Name="StackPanelInfoScrollViewer"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Background="{StaticResource DarkElevatedBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="Live inspector"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="The text below reflects the actual StackPanel instance on the left."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,3,0,12" />

              <TextBlock x:Name="PanelMetricsText"
                         Foreground="#DDEDF6"
                         Text="Panel metrics"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="ChildOrderText"
                         Foreground="#B6CCD9"
                         Text="Child order"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="VisibilitySummaryText"
                         Foreground="#B6CCD9"
                         Text="Visibility summary"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="AlignmentSummaryText"
                         Foreground="#B6CCD9"
                         Text="Alignment summary"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="ScrollSummaryText"
                         Foreground="#B6CCD9"
                         Text="Scroll summary"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="ObservationText"
                         Foreground="#D7EAF5"
                         Text="Observation"
                         TextWrapping="Wrap"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkElevatedBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="Capabilities covered"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Orientation changes the primary axis without changing the panel type." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
              <TextBlock Text="Child declaration order is the layout order unless you mutate the collection." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
              <TextBlock Text="Collapsed children stop participating in measurement and arrangement." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
              <TextBlock Text="Cross-axis alignment is controlled by each child, which is why the workbench exposes start, center, end, and stretch modes." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
              <TextBlock Text="ScrollViewer owns overflow; StackPanel keeps growing in one dimension." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkElevatedBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14">
            <StackPanel>
              <TextBlock Text="When not to use it"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="If the relationship between children is two-dimensional, reach for Grid instead of fighting StackPanel." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
              <TextBlock Text="If you need long generated item lists with scrolling, VirtualizingStackPanel is the better host because it can avoid realizing every child." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
              <TextBlock Text="Use StackPanel when the layout rule is fundamentally sequential and the simplest visual tree is the right answer." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>