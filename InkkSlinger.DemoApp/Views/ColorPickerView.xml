<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ColorPickerView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <Label Content="Control Demo: ColorPicker + ColorSpectrum Studio"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 FontSize="18"
                 FontWeight="SemiBold" />
          <TextBlock Text="A linked HSVA workbench that shows the square picker, both spectrum orientations, alpha handling, preset palettes, and live numeric readouts without a view model."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="{StaticResource OrangePrimaryBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <Label Content="Linked HSVA Lab"
                 Foreground="{StaticResource OrangePrimaryBrush}"
                 FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="360" />
      </Grid.ColumnDefinitions>

      <ScrollViewer Grid.Column="0"
                    Margin="0,0,10,0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="220" />
              </Grid.ColumnDefinitions>

              <ColorPicker x:Name="MainColorPicker"
                           Grid.Column="0"
                           Height="236"
                           Margin="0,0,12,0"
                           SelectedColorChanged="OnMainColorPickerSelectedColorChanged"
                           HorizontalAlignment="Stretch" />

              <ColorSpectrum x:Name="VerticalColorSpectrum"
                             Grid.Column="1"
                             Orientation="Vertical"
                             Height="236"
                             Width="24"
                             SelectedColorChanged="OnVerticalColorSpectrumSelectedColorChanged"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Stretch" />

                    <ColorSpectrum x:Name="AlphaColorSpectrum"
                       Grid.Column="2"
                       Mode="Alpha"
                       Orientation="Vertical"
                       Height="236"
                       Width="24"
                       Margin="12,0,0,0"
                       SelectedColorChanged="OnAlphaColorSpectrumSelectedColorChanged"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Stretch" />

                    <Border Grid.Column="3"
                      Background="{StaticResource DarkBgBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12"
                      Margin="16,0,0,0">
                <StackPanel>
                  <Label Content="Preview"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="16"
                         FontWeight="SemiBold" />
                  <TextBlock Text="The top swatch preserves alpha over a checkerboard. The lower swatch shows the same RGB as a fully opaque color."
                             Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,4,0,10" />

                  <Border Background="{StaticResource DarkElevatedBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,10">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                      </Grid.RowDefinitions>

                      <Label Grid.Row="0"
                             Content="Alpha preview"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             Margin="0,0,0,8" />

                      <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="#A0A0A0" />
                        <Border Grid.Row="0" Grid.Column="1" Background="#D8D8D8" />
                        <Border Grid.Row="1" Grid.Column="0" Background="#D8D8D8" />
                        <Border Grid.Row="1" Grid.Column="1" Background="#A0A0A0" />
                        <Border x:Name="AlphaPreviewOverlay"
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.RowSpan="2"
                                Grid.ColumnSpan="2"
                                BorderBrush="#F4F7FB"
                                BorderThickness="1" />
                      </Grid>
                    </Grid>
                  </Border>

                  <Border Background="{StaticResource DarkElevatedBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <Label Content="Opaque RGB"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             Margin="0,0,0,8" />
                      <Border x:Name="OpaquePreviewSwatch"
                              Height="52"
                              BorderBrush="#F4F7FB"
                              BorderThickness="1"
                              CornerRadius="4" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkElevatedBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10">
                    <StackPanel>
                      <Label Content="Interaction summary"
                             Foreground="{StaticResource TextSecondaryBrush}" />
                      <TextBlock x:Name="InteractionSummaryText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextWrapping="Wrap"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel>
              <Label Content="Horizontal hue spectrum"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
              <TextBlock Text="Orientation support is part of the ColorSpectrum contract, so this horizontal bar stays fully interactive and mirrors the same selected hue as the vertical bar."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,10" />
              <ColorSpectrum x:Name="HorizontalColorSpectrum"
                             Orientation="Horizontal"
                             Height="28"
                             SelectedColorChanged="OnHorizontalColorSpectrumSelectedColorChanged"
                             HorizontalAlignment="Stretch" />
              <TextBlock Text="The dedicated alpha spectrum now owns opacity selection separately from the ColorPicker surface, so hue and alpha can both be reused through the same control type."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14">
            <StackPanel>
              <Label Content="Preset palette"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
              <TextBlock Text="Each preset exercises a different part of the surface: pure hue, partial saturation, lifted value, and translucent alpha."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,10" />

              <WrapPanel>
                <Button x:Name="PresetScarletButton" Content="Scarlet" Margin="0,0,8,8" Padding="12,6" Click="OnPresetScarletClicked" />
                <Button x:Name="PresetLagoonButton" Content="Lagoon 65%" Margin="0,0,8,8" Padding="12,6" Click="OnPresetLagoonClicked" />
                <Button x:Name="PresetLimeButton" Content="Lime Glow" Margin="0,0,8,8" Padding="12,6" Click="OnPresetLimeClicked" />
                <Button x:Name="PresetLavenderButton" Content="Lavender Mist" Margin="0,0,8,8" Padding="12,6" Click="OnPresetLavenderClicked" />
                <Button x:Name="PresetSmokeButton" Content="Smoke 20%" Margin="0,0,8,8" Padding="12,6" Click="OnPresetSmokeClicked" />
                <Button x:Name="PresetSunsetButton" Content="Sunset" Margin="0,0,8,8" Padding="12,6" Click="OnPresetSunsetClicked" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer Grid.Column="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel>
              <Label Content="Live output"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
              <TextBlock x:Name="HexValueText"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Margin="0,10,0,4" />
              <TextBlock x:Name="ArgbValueText"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Margin="0,0,0,4" />
              <TextBlock x:Name="HsvaValueText"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Margin="0,0,0,4" />
              <TextBlock x:Name="CapabilitySummaryText"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
            <StackPanel>
              <Label Content="Channel sliders"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
              <TextBlock Text="These use the normal Slider control to prove the color surfaces can be driven from external channel editors without a view model."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,10" />

              <Label x:Name="HueSliderLabel" Content="Hue: 0°" Foreground="{StaticResource TextSecondaryBrush}" />
              <Slider x:Name="HueSlider" Minimum="0" Maximum="360" Value="0" SmallChange="1" LargeChange="15" TickPlacement="BottomRight" TickFrequency="30" Margin="0,0,0,10" ValueChanged="OnChannelSliderChanged" />

              <Label x:Name="SaturationSliderLabel" Content="Saturation: 100%" Foreground="{StaticResource TextSecondaryBrush}" />
              <Slider x:Name="SaturationSlider" Minimum="0" Maximum="100" Value="100" SmallChange="1" LargeChange="10" TickPlacement="BottomRight" TickFrequency="10" Margin="0,0,0,10" ValueChanged="OnChannelSliderChanged" />

              <Label x:Name="ValueSliderLabel" Content="Value: 100%" Foreground="{StaticResource TextSecondaryBrush}" />
              <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="100" SmallChange="1" LargeChange="10" TickPlacement="BottomRight" TickFrequency="10" Margin="0,0,0,10" ValueChanged="OnChannelSliderChanged" />

              <Label x:Name="AlphaSliderLabel" Content="Alpha: 100%" Foreground="{StaticResource TextSecondaryBrush}" />
              <Slider x:Name="AlphaSlider" Minimum="0" Maximum="100" Value="100" SmallChange="1" LargeChange="10" TickPlacement="BottomRight" TickFrequency="10" ValueChanged="OnChannelSliderChanged" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14">
            <StackPanel>
              <Label Content="Demo notes"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
              <TextBlock Text="1. Drag inside the square to change saturation and value.
2. Drag either hue spectrum to change hue.
3. Drag the dedicated alpha spectrum to change alpha.
4. Use the sliders or preset buttons and watch every surface stay in sync."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>