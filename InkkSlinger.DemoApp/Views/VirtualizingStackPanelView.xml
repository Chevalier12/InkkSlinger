<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.VirtualizingStackPanelView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Control Demo: VirtualizingStackPanel Workbench"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
          <TextBlock Text="A WPF-style workbench for orientation, cache policy, virtualization mode, direct panel scrolling, realized-range diagnostics, and the canonical ListBox plus ItemsPanelTemplate integration path."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#7BC4A8"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="Offsets • Cache • Realization"
                     Foreground="#D3F5E7"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource DarkBgBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="320" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Live panel playground" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="This surface hosts a real VirtualizingStackPanel inside its own viewport so mouse-wheel scrolling, scrollbars, line and page jumps, and visibility targeting all operate against the same scrolling owner." />

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                  <StackPanel>
                    <WrapPanel Margin="0,0,0,10">
                      <ComboBox x:Name="OrientationComboBox"
                                Width="150"
                                Margin="0,0,10,8" />
                      <ComboBox x:Name="VirtualizationModeComboBox"
                                Width="170"
                                Margin="0,0,10,8" />
                      <ComboBox x:Name="CacheUnitComboBox"
                                Width="154"
                                Margin="0,0,12,8" />
                      <CheckBox x:Name="IsVirtualizingCheckBox"
                                Content="Virtualization enabled"
                                Margin="0,0,12,8"
                                IsChecked="True" />
                      <CheckBox x:Name="VariableHeightsCheckBox"
                                Content="Variable item sizes"
                                Margin="0,0,12,8"
                                IsChecked="True" />
                      <CheckBox x:Name="DenseCardsCheckBox"
                                Content="Dense card layout"
                                Margin="0,0,0,8" />
                    </WrapPanel>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <StackPanel Grid.Column="0">
                        <TextBlock Text="Cache length"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <Slider x:Name="CacheLengthSlider"
                                Minimum="0"
                                Maximum="4"
                                Value="1"
                                TickFrequency="0.25"
                                IsSnapToTickEnabled="True"
                                TickPlacement="BottomRight"
                                Margin="0,6,0,0" />
                        <TextBlock x:Name="CacheLengthValueText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Cache length"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                      </StackPanel>

                      <StackPanel Grid.Column="2">
                        <TextBlock Text="Target item for MakeVisible"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                        <Slider x:Name="TargetIndexSlider"
                                Minimum="0"
                                Maximum="159"
                                Value="72"
                                TickFrequency="8"
                                IsSnapToTickEnabled="True"
                                TickPlacement="BottomRight"
                                Margin="0,6,0,0" />
                        <TextBlock x:Name="TargetIndexValueText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Target item"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Background="#10161B"
                        BorderBrush="#38566B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                  <StackPanel>
                    <TextBlock x:Name="WorkbenchNarrativeText"
                               Foreground="#DCEEF7"
                               Text="Narrative"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkbenchMetricsInlineText"
                               Foreground="#A9C7D8"
                               Text="Inline metrics"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                  </StackPanel>
                </Border>

                    <Border Background="#0D1318"
                    BorderBrush="#345364"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Height="420"
                    ClipToBounds="True">
                  <ScrollViewer x:Name="WorkbenchScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        Background="#0D1318"
                        BorderBrush="#345364"
                        BorderThickness="0">
                    <VirtualizingStackPanel x:Name="WorkbenchPanel"
                            ClipToBounds="True"
                            Orientation="Vertical"
                            IsVirtualizing="True"
                            VirtualizationMode="Standard"
                            CacheLength="1"
                            CacheLengthUnit="Page" />
                  </ScrollViewer>
                    </Border>

                <WrapPanel Margin="0,12,0,0">
                  <Button x:Name="LineBackButton" Content="Line back" Margin="0,0,8,8" />
                  <Button x:Name="LineForwardButton" Content="Line forward" Margin="0,0,8,8" />
                  <Button x:Name="PageBackButton" Content="Page back" Margin="0,0,8,8" />
                  <Button x:Name="PageForwardButton" Content="Page forward" Margin="0,0,8,8" />
                  <Button x:Name="JumpStartButton" Content="Jump to start" Margin="0,0,8,8" />
                  <Button x:Name="JumpMiddleButton" Content="Jump to middle" Margin="0,0,8,8" />
                  <Button x:Name="JumpEndButton" Content="Jump to end" Margin="0,0,8,8" />
                  <Button x:Name="RevealTargetButton" Content="Make target visible" Margin="0,0,0,8" />
                </WrapPanel>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="WorkbenchActionText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Action summary"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="WorkbenchTargetSummaryText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Target summary"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel>
                <Label Content="WPF-style ItemsPanelTemplate sample" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="This is the consumer-facing pattern most WPF code would write: a ListBox owns selection and scrolling while a VirtualizingStackPanel is injected as the items host. The item template stays rich, but virtualization remains part of the layout story instead of a separate feature." />

                <WrapPanel Margin="0,0,0,10">
                  <Button x:Name="ListJumpStartButton" Content="ScrollIntoView first" Margin="0,0,8,8" />
                  <Button x:Name="ListJumpMiddleButton" Content="ScrollIntoView middle" Margin="0,0,8,8" />
                  <Button x:Name="ListJumpEndButton" Content="ScrollIntoView last" Margin="0,0,8,8" />
                  <Button x:Name="ListResetSelectionButton" Content="Reset selection" Margin="0,0,0,8" />
                </WrapPanel>

                <ListBox x:Name="TemplateListBox"
                         Height="360"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Top"
                         SelectedValuePath="Id"
                         ItemsSource="{Binding Path=TemplateItems}">
                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel Orientation="Vertical"
                                              IsVirtualizing="True"
                                              VirtualizationMode="Recycling"
                                              CacheLength="1.25"
                                              CacheLengthUnit="Page" />
                    </ItemsPanelTemplate>
                  </ListBox.ItemsPanel>
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#16212A"
                              BorderBrush="#3C596B"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,6">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Path=Title}"
                                       Foreground="#E5F1F8"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Path=Summary}"
                                       Foreground="#B7CDDA"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Path=OwnerLine}"
                                       Foreground="#8FB2C7"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                          </StackPanel>

                          <Border Grid.Column="1"
                                  Background="#213643"
                                  BorderBrush="#5F8298"
                                  BorderThickness="1"
                                  CornerRadius="12"
                                  Padding="10,4"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Top">
                            <TextBlock Text="{Binding Path=Status}"
                                       Foreground="#D7EAF7"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="TemplateListSummaryText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Template list summary"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TemplateSelectionSummaryText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Template selection summary"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Runtime diagnostics" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="PanelStateText"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Panel state"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="RealizationStateText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Realization state"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock x:Name="OffsetStateText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Offset state"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock x:Name="ExtentStateText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Extent state"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock x:Name="VisualTreeStateText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Visual tree state"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock x:Name="TargetStateText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Target state"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Capabilities in view" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Orientation: switch between a vertical backlog and a horizontal card rail without replacing the panel type." />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Text="Cache policy: move between page, item, and pixel cache semantics and watch the realized range widen or tighten." />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Text="Direct scroll API: line, page, absolute offset, and MakeVisible are all driven against the VirtualizingStackPanel itself." />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"
                           Text="ItemsControl integration: the lower sample uses the familiar WPF ListBox plus ItemsPanelTemplate composition path." />
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel>
                <Label Content="What to watch for" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="ObservationText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Observation"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="SelectedTemplateItemText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Selected template item"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






