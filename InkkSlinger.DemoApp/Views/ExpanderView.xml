<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ExpanderView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Control Demo: Expander"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
          <TextBlock Text="A dedicated Expander workbench covering header content, expand directions, manual accordion behavior, and the Expanded or Collapsed routed events."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#73C6D4"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="Header • Direction • Events"
                     Foreground="#BEEBF3"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource DarkBgBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="320" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Live playground" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Use the live controls to change IsExpanded, swap expand directions, and replace the header text with a richer visual tree. The same Expander instance stays on screen while its state changes." />

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,12">
                  <WrapPanel>
                    <Button x:Name="PlaygroundExpandButton" Content="Expand" Margin="0,0,8,8" />
                    <Button x:Name="PlaygroundCollapseButton" Content="Collapse" Margin="0,0,8,8" />
                    <Button x:Name="PlaygroundToggleButton" Content="Toggle" Margin="0,0,8,8" />
                    <Button x:Name="PlaygroundResetButton" Content="Reset demo" Margin="0,0,12,8" />
                    <ComboBox x:Name="PlaygroundDirectionCombo"
                              Width="164"
                              Margin="0,0,12,8" />
                    <CheckBox x:Name="PlaygroundAccentCheckBox"
                              Content="Accent palette"
                              Margin="0,0,12,8"
                              IsChecked="True" />
                    <CheckBox x:Name="PlaygroundRichHeaderCheckBox"
                              Content="Rich header"
                              Margin="0,0,0,8"
                              IsChecked="True" />
                  </WrapPanel>
                </Border>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        MinHeight="260">
                  <Expander x:Name="PlaygroundExpander"
                            IsExpanded="True"
                            Header="Release checklist"
                            Padding="12"
                            HeaderPadding="14,10,14,10">
                    <Border Background="#172127"
                            BorderBrush="#325260"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                      <StackPanel>
                        <TextBlock Text="A live release checklist gives the content area enough density to make open and collapsed changes obvious."
                                   Foreground="#D8EEF3"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <Border Background="#20343D"
                                BorderBrush="#406573"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10"
                                Margin="0,0,0,8">
                          <TextBlock Text="QA pass: verify keyboard and pointer access around the header hit-target."
                                     Foreground="#E9F9FD"
                                     TextWrapping="Wrap" />
                        </Border>

                        <Border Background="#20343D"
                                BorderBrush="#406573"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10"
                                Margin="0,0,0,8">
                          <TextBlock Text="Telemetry pass: watch Expanded and Collapsed counts update without recreating the control."
                                     Foreground="#E9F9FD"
                                     TextWrapping="Wrap" />
                        </Border>

                        <Border Background="#20343D"
                                BorderBrush="#406573"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                          <TextBlock Text="Direction pass: switch to Up, Left, or Right to see the header consume a different edge before content is arranged."
                                     Foreground="#E9F9FD"
                                     TextWrapping="Wrap" />
                        </Border>
                      </StackPanel>
                    </Border>
                  </Expander>
                </Border>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="PlaygroundStateText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="State"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="PlaygroundEventCountsText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Events"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel>
                <Label Content="Accordion pattern" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="Expander does not enforce accordion behavior on its own. This section demonstrates the common pattern: handle Expanded and collapse sibling panels yourself." />

                <Expander x:Name="AccordionPlanningExpander"
                          Header="Planning review"
                          IsExpanded="True"
                          Margin="0,0,0,8">
                  <Border Background="#252A31"
                          BorderBrush="#485361"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <TextBlock Text="Clarify scope, capture open questions, and confirm what the header needs to communicate before the content appears."
                                 Foreground="#E4EAF0"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="Use this pattern when one section should dominate attention while the others stay collapsed." 
                                 Foreground="#B8C2CC"
                                 TextWrapping="Wrap"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </Expander>

                <Expander x:Name="AccordionTokensExpander"
                          Header="Design tokens"
                          Margin="0,0,0,8">
                  <Border Background="#25282F"
                          BorderBrush="#4F5968"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <TextBlock Text="HeaderBackground, BorderBrush, Foreground, HeaderPadding, and Padding are enough to create a distinct visual lane without a custom template." 
                                 Foreground="#E4EAF0"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="This keeps the demo close to the control API instead of depending on a style-only showcase." 
                                 Foreground="#B8C2CC"
                                 TextWrapping="Wrap"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </Expander>

                <Expander x:Name="AccordionPublishingExpander"
                          Header="Publishing checklist">
                  <Border Background="#282722"
                          BorderBrush="#645B42"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <TextBlock Text="Document the intended header behavior, make the disabled and collapsed states visible, and include a live sample that users can manipulate." 
                                 Foreground="#EEE7D7"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="That combination turns a placeholder sample into a real control workbench." 
                                 Foreground="#D1C5AF"
                                 TextWrapping="Wrap"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </Expander>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,12,0,0">
                  <StackPanel>
                    <TextBlock x:Name="AccordionStateText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Accordion state"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="AccordionEventCountsText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Accordion events"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Direction showcase" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="All four ExpandDirection values are supported. The samples stay expanded so the header edge and content placement remain visible at a glance." />

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,8">
                  <Expander Header="Down direction"
                            IsExpanded="True">
                    <Border Background="#2A3138"
                            BorderBrush="#495667"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                      <TextBlock Text="The default direction stacks content under the header." Foreground="#E7EDF3" TextWrapping="Wrap" />
                    </Border>
                  </Expander>
                </Border>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,8">
                  <Expander Header="Up direction"
                            ExpandDirection="Up"
                            IsExpanded="True">
                    <Border Background="#2F2C38"
                            BorderBrush="#5A5671"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                      <TextBlock Text="Content is arranged above the header when the panel opens upward." Foreground="#EEE9F9" TextWrapping="Wrap" />
                    </Border>
                  </Expander>
                </Border>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,8">
                  <Expander Header="Left direction"
                            ExpandDirection="Left"
                            IsExpanded="True">
                    <Border Background="#312C29"
                            BorderBrush="#6C6054"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                      <TextBlock Text="The header moves to the right edge and content claims the space on its left." Foreground="#F4EBE3" TextWrapping="Wrap" />
                    </Border>
                  </Expander>
                </Border>

                <Border Background="{StaticResource DarkBgBrush}"
                        BorderBrush="{StaticResource DarkBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                  <Expander Header="Right direction"
                            ExpandDirection="Right"
                            IsExpanded="True">
                    <Border Background="#263229"
                            BorderBrush="#4F6954"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                      <TextBlock Text="The header stays on the left edge and content opens into the remaining width on the right." Foreground="#E2F1E5" TextWrapping="Wrap" />
                    </Border>
                  </Expander>
                </Border>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
              <StackPanel>
                <Label Content="Custom header and states" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="This sample keeps a richer header element applied all the time, then places collapsed-on-load and disabled examples underneath so the main state variants are visible without extra clicks." />

                <Expander x:Name="StyledExpander"
                          IsExpanded="True"
                          Padding="12"
                          HeaderPadding="14,10,14,10"
                          Background="#152029"
                          HeaderBackground="#1B4658"
                          BorderBrush="#5FA8C4"
                          Foreground="#F2FBFF"
                          Margin="0,0,0,10">
                  <Border Background="#11212B"
                          BorderBrush="#31596A"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <TextBlock Text="Header accepts any object, including a composed UI tree with title and supporting copy."
                                 Foreground="#F0FBFF"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="This keeps the demo focused on the control surface instead of relying on a template swap."
                                 Foreground="#C9EAF2"
                                 TextWrapping="Wrap"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                  </Border>
                </Expander>

                <Expander Header="Collapsed on load"
                          IsExpanded="False"
                          Margin="0,0,0,8">
                  <Border Background="#2A2A2A"
                          BorderBrush="#4C4C4C"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="10">
                    <TextBlock Text="Keep this closed initially when the surrounding view would otherwise feel too dense." Foreground="#F1F1F1" TextWrapping="Wrap" />
                  </Border>
                </Expander>

                <Expander Header="Disabled"
                          IsExpanded="True"
                          IsEnabled="False">
                  <Border Background="#2A2A2A"
                          BorderBrush="#4C4C4C"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="10">
                    <TextBlock Text="IsEnabled=false suppresses header interaction and renders the control in its disabled state." Foreground="#D0D0D0" TextWrapping="Wrap" />
                  </Border>
                </Expander>
              </StackPanel>
            </Border>

            <Border Background="{StaticResource DarkElevatedBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel>
                <Label Content="Live notes" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="CatalogSummaryText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Summary" />
                <TextBlock x:Name="DirectionSummaryText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Text="Direction summary" />
                <TextBlock x:Name="StateSummaryText"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Text="State summary" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






