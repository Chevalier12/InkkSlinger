<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.AccessTextView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: AccessText" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="AccessText parses underscore markup into display text, underlines the first mnemonic character, and routes that access key to a named or implicit target. This workbench lets you edit markup live, inspect the parsed result, execute access keys against buttons and text inputs, and compare wrapped and styled rendering." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Interactive playground" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Edit the raw AccessText markup and its TargetName, then execute the resolved access key through the same internal service used by keyboard input." />

                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Raw Text" />
                  <TextBox x:Name="LiveMarkupEditor"
                           Text="_Run primary action"
                           Margin="0,4,0,10" />

                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="TargetName" />
                  <TextBox x:Name="TargetNameEditor"
                           Text="PrimaryWorkbenchButton"
                           Margin="0,4,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="LoadPrimaryPresetButton" Content="Load primary preset" Margin="0,0,8,8" />
                    <Button x:Name="LoadEscapedPresetButton" Content="Load escaped preset" Margin="0,0,8,8" />
                    <Button x:Name="LoadFocusPresetButton" Content="Load focus preset" Margin="0,0,8,8" />
                    <Button x:Name="SimulateLiveAccessKeyButton"
                            Content="Simulate current access key"
                            Background="{StaticResource OrangePrimaryBrush}"
                            BorderBrush="{StaticResource OrangeDarkBrush}"
                            Foreground="{StaticResource DarkBgBrush}"
                            Margin="0,0,0,8" />
                  </WrapPanel>

                  <Border Background="{StaticResource DarkBgBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                 Text="Rendered preview"
                                 Margin="0,0,0,8" />
                      <AccessText x:Name="LivePreviewAccessText"
                                  Text="_Run primary action"
                                  TargetName="PrimaryWorkbenchButton"
                                  FontSize="22"
                                  TextWrapping="Wrap"
                                  Margin="0,0,0,12" />
                      <WrapPanel Margin="0,0,0,10">
                        <Button x:Name="PrimaryWorkbenchButton" Content="Primary target" Margin="0,0,8,8" />
                        <Button x:Name="SecondaryWorkbenchButton" Content="Secondary target" Margin="0,0,8,8" />
                        <TextBox x:Name="SearchTargetTextBox"
                                 Width="220"
                                 Text="Focus lands here when the target is a text input."
                                 Margin="0,0,0,8" />
                      </WrapPanel>
                      <TextBlock x:Name="PrimaryInvokeCountText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Primary target clicks: 0" />
                      <TextBlock x:Name="SecondaryInvokeCountText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Secondary target clicks: 0"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                  </Border>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                      <TextBlock x:Name="ParsedDisplayText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Display text: Run primary action" />
                      <TextBlock x:Name="ParsedAccessKeyText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Access key: R"
                                 Margin="0,4,0,0" />
                      <TextBlock x:Name="ParsedIndexText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Access key display index: 0"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                      <TextBlock x:Name="ResolvedTargetText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Resolved target: PrimaryWorkbenchButton (Button)" />
                      <TextBlock x:Name="FocusedElementText"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Text="Focused element: none"
                                 Margin="0,4,0,0" />
                      <TextBlock x:Name="LiveSimulationStatusText"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"
                                 Text="Simulation status: idle"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Parsing rules" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="AccessText removes single underscore markers, keeps escaped double underscores as a literal underscore, and only the first letter or digit after an underscore becomes the active mnemonic." />

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                      <AccessText Text="_Open project" FontSize="18" Margin="0,0,0,4" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Text="Raw: _Open project | Display: Open project | Access key: O" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                      <AccessText Text="Save __As" FontSize="18" Margin="0,0,0,4" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Text="Raw: Save __As | Display: Save _As | Access key: none" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                      <AccessText Text="Version _2 rollout" FontSize="18" Margin="0,0,0,4" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Text="Digits can be mnemonics too. Raw: Version _2 rollout | Access key: 2" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel>
                      <AccessText Text="_First key wins, _second marker only removes the underscore" FontSize="18" TextWrapping="Wrap" />
                      <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" Text="Only the first valid mnemonic is active. Later underscore markers still strip from the displayed string but do not register another access key." />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Target workbench" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Different AccessText instances can target different controls. Buttons invoke, while text inputs receive focus." />

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                      <AccessText Text="_Approve item" TargetName="ApproveItemButton" FontSize="18" Margin="0,0,0,8" />
                      <Button x:Name="ApproveItemButton" Content="Approve item" Margin="0,0,0,6" />
                      <TextBlock x:Name="ApproveCountText" Foreground="{StaticResource TextPrimaryBrush}" Text="Approve clicks: 0" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                      <AccessText Text="_Queue item" TargetName="QueueItemButton" FontSize="18" Margin="0,0,0,8" />
                      <Button x:Name="QueueItemButton" Content="Queue item" Margin="0,0,0,6" />
                      <TextBlock x:Name="QueueCountText" Foreground="{StaticResource TextPrimaryBrush}" Text="Queue clicks: 0" />
                    </StackPanel>
                  </Border>

                  <Border Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                      <AccessText Text="_Owner filter" TargetName="OwnerFilterTextBox" FontSize="18" Margin="0,0,0,8" />
                      <TextBox x:Name="OwnerFilterTextBox" Text="Typing target for Alt+O" />
                    </StackPanel>
                  </Border>

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="SimulateApproveButton" Content="Simulate Alt+A" Margin="0,0,8,8" />
                    <Button x:Name="SimulateQueueButton" Content="Simulate Alt+Q" Margin="0,0,8,8" />
                    <Button x:Name="SimulateOwnerButton" Content="Simulate Alt+O" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="CommandBoardStatusText"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Text="Command board status: idle" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Label integration" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="ContentPresenter recognizes access keys too. A Label hosting underscored content can route the mnemonic to its Target without setting AccessText.TargetName explicitly." />

                  <Label x:Name="ProjectNameLabel"
                         Content="_Project name"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Margin="0,0,0,6" />
                  <TextBox x:Name="ProjectNameTextBox"
                           Text="Atlas"
                           Margin="0,0,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="SimulateLabelAccessKeyButton" Content="Simulate Alt+P" Margin="0,0,8,8" />
                    <Button x:Name="FocusQueueButton" Content="Focus queue button first" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="LabelDemoStatusText"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Text="Label demo status: idle" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Wrapping and styling" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Because AccessText inherits TextBlock, it supports the usual text styling and wrapping behaviors while keeping the mnemonic underline aligned with wrapped content." />

                  <Border Background="#18212A" BorderBrush="#334A5C" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                    <AccessText Text="Review the _deployment checklist before promoting this build to the shared preview environment."
                                TextWrapping="Wrap"
                                Width="270"
                                FontSize="20"
                                Foreground="#D7EEFF" />
                  </Border>

                  <Border Background="#2A1C10" BorderBrush="#A96B2C" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel>
                      <AccessText Text="_Launch high-contrast preview"
                                  FontSize="24"
                                  FontWeight="SemiBold"
                                  Foreground="#FFD39A"
                                  Margin="0,0,0,6" />
                      <TextBlock Foreground="#E0B37C"
                                 TextWrapping="Wrap"
                                 Text="Foreground color, typography, and layout constraints apply exactly like TextBlock because AccessText only changes parsing and underline rendering." />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






