<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.Designer.DesignerSourceEditorView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
  <UserControl.Resources>
    <DataTemplate x:Key="CompletionItemTemplate">
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center">
        <Border Width="16"
                Height="16"
                VerticalAlignment="Center"
                Margin="0,0,6,0">
            <Path Data="M 3,3.5 L 13,3.5 M 3,6.5 L 11.5,6.5 M 3,9.5 L 13,9.5 M 3,12.5 L 9.5,12.5"
              Fill="Transparent"
              Stroke="#74B9FF"
              StrokeThickness="1.25"
              Stretch="Uniform" />
        </Border>
        <TextBlock Text="{Binding ElementName}"
                   Foreground="#F0F7FF"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <Style x:Key="CompletionListBoxItemStyle"
           TargetType="{x:Type ListBoxItem}">
      <Setter Property="Background" Value="#0B1018" />
      <Setter Property="SelectedBackground" Value="#094771" />
      <Setter Property="BorderBrush" Value="#0B1018" />
      <Setter Property="Foreground" Value="#F0F7FF" />
      <Setter Property="Padding" Value="4,3,8,3" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#142132" />
          <Setter Property="BorderBrush" Value="#233449" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompletionListBoxStyle"
           TargetType="{x:Type ListBox}">
      <Setter Property="Background" Value="#0B1018" />
      <Setter Property="BorderBrush" Value="#233449" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="IsVirtualizing" Value="True" />
      <Setter Property="MinWidth" Value="180" />
      <Setter Property="MaxWidth" Value="420" />
      <Setter Property="MaxHeight" Value="260" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="ItemTemplate" Value="{StaticResource CompletionItemTemplate}" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource CompletionListBoxItemStyle}" />
    </Style>

    <Style x:Key="CompletionPopupStyle"
           TargetType="{x:Type Popup}">
      <Setter Property="TitleBarHeight" Value="0" />
      <Setter Property="CanClose" Value="False" />
      <Setter Property="CanDragMove" Value="False" />
      <Setter Property="DismissOnOutsideClick" Value="True" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#233449" />
      <Setter Property="Background" Value="#090D13" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="PlacementMode" Value="Absolute" />
    </Style>

    <Style x:Key="DesignerComboBoxItemStyle"
           TargetType="{x:Type ComboBoxItem}">
      <Setter Property="Background" Value="#090D13" />
      <Setter Property="SelectedBackground" Value="#1A4A7A" />
      <Setter Property="BorderBrush" Value="#090D13" />
      <Setter Property="Foreground" Value="#D8E3EE" />
      <Setter Property="Padding" Value="8,6,8,6" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#142132" />
          <Setter Property="BorderBrush" Value="#233449" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#1A4A7A" />
          <Setter Property="BorderBrush" Value="#2D5D8D" />
          <Setter Property="Foreground" Value="#F0F7FF" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DesignerComboBoxDropDownListStyle"
           TargetType="{x:Type ListBox}">
      <Setter Property="Background" Value="#090D13" />
      <Setter Property="Foreground" Value="#D8E3EE" />
      <Setter Property="BorderBrush" Value="#233449" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DesignerComboBoxDropDownPopupStyle"
           TargetType="{x:Type Popup}">
      <Setter Property="TitleBarHeight" Value="0" />
      <Setter Property="CanClose" Value="False" />
      <Setter Property="CanDragMove" Value="False" />
      <Setter Property="DismissOnOutsideClick" Value="True" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#233449" />
      <Setter Property="Background" Value="#090D13" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="DesignerInspectorComboBoxStyle"
           TargetType="{x:Type ComboBox}">
      <Setter Property="Background" Value="#081018" />
      <Setter Property="Foreground" Value="#D8E3EE" />
      <Setter Property="BorderBrush" Value="#243342" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,5,8,5" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DesignerInspectorTextBoxStyle"
           TargetType="{x:Type TextBox}">
      <Setter Property="Background" Value="#081018" />
      <Setter Property="Foreground" Value="#D8E3EE" />
      <Setter Property="BorderBrush" Value="#243342" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,5,8,5" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <DataTemplate x:Key="SourcePropertyTextEditorTemplate">
      <TextBox Style="{StaticResource DesignerInspectorTextBoxStyle}"
               TextChanged="OnSourcePropertyEditorTextChanged"
               Text="{Binding EditorText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <DataTemplate x:Key="SourcePropertyChoiceEditorTemplate">
      <ComboBox Style="{StaticResource DesignerInspectorComboBoxStyle}"
                SelectionChanged="OnSourcePropertyChoiceSelectionChanged"
                ItemsSource="{Binding ChoiceValues}"
                SelectedItem="{Binding SelectedChoice, Mode=TwoWay}"
                ItemContainerStyle="{StaticResource DesignerComboBoxItemStyle}"
                DropDownListStyle="{StaticResource DesignerComboBoxDropDownListStyle}"
                DropDownPopupStyle="{StaticResource DesignerComboBoxDropDownPopupStyle}"
                MaxDropDownHeight="240" />
    </DataTemplate>

    <DataTemplate x:Key="SourcePropertyCompositeEditorTemplate">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="{Binding CompositeComponent1.Label}"
                     Foreground="#4A6880"
                     FontSize="10"
                     Margin="0,0,0,4" />
          <TextBox Style="{StaticResource DesignerInspectorTextBoxStyle}"
                   Tag="{Binding CompositeComponent1}"
                   TextChanged="OnSourcePropertyCompositeTextChanged"
                   Text="{Binding CompositeComponent1.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock Text="{Binding CompositeComponent2.Label}"
                     Foreground="#4A6880"
                     FontSize="10"
                     Margin="0,0,0,4" />
          <TextBox Style="{StaticResource DesignerInspectorTextBoxStyle}"
                   Tag="{Binding CompositeComponent2}"
                   TextChanged="OnSourcePropertyCompositeTextChanged"
                   Text="{Binding CompositeComponent2.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Column="4">
          <TextBlock Text="{Binding CompositeComponent3.Label}"
                     Foreground="#4A6880"
                     FontSize="10"
                     Margin="0,0,0,4" />
          <TextBox Style="{StaticResource DesignerInspectorTextBoxStyle}"
                   Tag="{Binding CompositeComponent3}"
                   TextChanged="OnSourcePropertyCompositeTextChanged"
                   Text="{Binding CompositeComponent3.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Column="6">
          <TextBlock Text="{Binding CompositeComponent4.Label}"
                     Foreground="#4A6880"
                     FontSize="10"
                     Margin="0,0,0,4" />
          <TextBox Style="{StaticResource DesignerInspectorTextBoxStyle}"
                   Tag="{Binding CompositeComponent4}"
                   TextChanged="OnSourcePropertyCompositeTextChanged"
                   Text="{Binding CompositeComponent4.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SourcePropertyColorEditorTemplate">
      <DesignerSourceColorPropertyEditor PropertyName="{Binding Name}"
                                         DisplayText="{Binding ColorDisplayText}"
                                         SelectedColorValue="{Binding SelectedColor}" />
    </DataTemplate>

    <DesignerSourceInspectorEditorTemplateSelector x:Key="SourcePropertyEditorTemplateSelector"
                                                   TextTemplate="{StaticResource SourcePropertyTextEditorTemplate}"
                                                   ChoiceTemplate="{StaticResource SourcePropertyChoiceEditorTemplate}"
                                                   CompositeTemplate="{StaticResource SourcePropertyCompositeEditorTemplate}"
                                                   ColorTemplate="{StaticResource SourcePropertyColorEditorTemplate}" />

    <DataTemplate x:Key="SourcePropertyRowTemplate">
      <Border Background="#0B1118"
              BorderBrush="#0F1A26"
              BorderThickness="0,0,0,1"
              Padding="0,0,0,10"
              Margin="0,0,0,10"
              Visibility="{Binding RowVisibility}">
        <StackPanel>
          <TextBlock Text="{Binding Name}"
                     Foreground="#C8D8E8"
                     FontSize="12"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding DescriptionText}"
                     Foreground="#4A6880"
                     FontSize="10"
                     Margin="0,2,0,6"
                     TextWrapping="Wrap" />
          <ContentControl Content="{Binding}"
                          ContentTemplateSelector="{StaticResource SourcePropertyEditorTemplateSelector}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="8" />
      <ColumnDefinition Width="320" MinWidth="220" />
    </Grid.ColumnDefinitions>

    <IDE_Editor x:Name="SourceEditor"
                Grid.Column="0"
                TextChanged="OnSourceEditorTextChanged"
                ViewportChanged="OnSourceEditorViewportChanged"
                LayoutUpdated="OnSourceEditorLayoutUpdated"
                Background="#0D131A"
                BorderThickness="0"
                Foreground="#D8E3EE"
                CaretBrush="#7FD0FF"
                SelectionBrush="#1A4A7A"
                Padding="10"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                AcceptsReturn="True"
                AcceptsTab="True"
                TextWrapping="NoWrap"
                FontFamily="Consolas"
                FontSize="16"
                LineNumberBackground="#0A1017"
                LineNumberForeground="#4A6880"
                LineNumberSeparatorBrush="#1A2637" />

    <GridSplitter x:Name="SourcePropertyInspectorSplitter"
                  Grid.Column="1"
                  Background="#0B0F14"
                  BorderBrush="#1E3450"
                  BorderThickness="1,0,1,0"
                  Margin="1,0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ResizeBehavior="PreviousAndNext" />

    <Border x:Name="SourcePropertyInspectorBorder"
      Grid.Column="2"
            Background="#0D131A"
            BorderBrush="#1A2637"
            BorderThickness="1,0,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#1A2637"
                BorderThickness="0,0,0,1"
                Padding="10,8">
          <StackPanel>
            <TextBlock Text="Property Inspector"
                       Foreground="#C8D8E8"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="SourcePropertyInspectorHeaderText"
                       Foreground="#8DA1B5"
                       FontSize="12"
                       Margin="0,3,0,0"
                       Text="Select a control tag in the source editor." />
            <TextBlock x:Name="SourcePropertyInspectorSummaryText"
                       Foreground="#4A6880"
                       FontSize="11"
                       Margin="0,3,0,0"
                       Text="Changes update the XML source. Press F5 to refresh the preview." />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border x:Name="SourcePropertyInspectorFilterBorder"
                  Grid.Row="0"
                  BorderBrush="#1A2637"
                  BorderThickness="0,0,0,1"
                  Padding="8,8,8,6"
                  Visibility="Collapsed">
            <StackPanel>
              <TextBlock Text="Filter properties"
                         Foreground="#4A6880"
                         FontSize="11"
                         Margin="0,0,0,4" />
              <TextBox x:Name="SourcePropertyInspectorFilterTextBox"
                       TextChanged="OnSourcePropertyInspectorFilterTextChanged"
                       Background="#081018"
                       Foreground="#D8E3EE"
                       BorderBrush="#243342"
                       BorderThickness="1"
                       Padding="8,5,8,5"
                       FontFamily="Consolas" />
            </StackPanel>
          </Border>

          <Grid Grid.Row="1">
            <TextBlock x:Name="SourcePropertyInspectorEmptyState"
                       Foreground="#4A6880"
                       Margin="12"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"
                       Text="Place the caret inside a control start tag such as &lt;Button /&gt; or &lt;Button&gt; to edit its properties." />

            <ScrollViewer x:Name="SourcePropertyInspectorScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed">
              <ItemsControl x:Name="SourcePropertyInspectorPropertiesHost"
                            Margin="8,8,8,10"
                            ItemsSource="{Binding SourcePropertyInspectorItems, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DesignerSourceEditorView}}}"
                            ItemTemplate="{StaticResource SourcePropertyRowTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Grid>
    </Border>

    <Popup x:Name="CompletionPopup"
           Style="{StaticResource CompletionPopupStyle}"
           MaxHeight="260">
      <ListBox x:Name="CompletionListBox"
               Style="{StaticResource CompletionListBoxStyle}" />
    </Popup>
  </Grid>
</UserControl>