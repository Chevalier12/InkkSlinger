<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.Designer.DesignerShellView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#0B0F14">
  <UserControl.Resources>
    <DataTemplate x:Key="PreviewPlaceholderTemplate">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Width="420">
        <Border Width="56"
                Height="4"
          Background="{Binding Accent}"
                Margin="0,0,0,16" />
        <TextBlock Text="{Binding Title}"
                   Foreground="#E7EDF5"
                   FontSize="24"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Body}"
             Foreground="{Binding BodyColor}"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="VisualTreeNodeTemplate">
      <StackPanel Margin="{Binding IndentMargin}">
        <Border Background="{Binding RowBackground}"
                BorderBrush="{Binding RowBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="4">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                  Content="{Binding ExpandGlyph}"
                    Width="20"
                    Height="20"
                    Padding="0"
                    Margin="0,0,6,0"
                    Background="Transparent"
                    Foreground="#6F8DAA"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Visibility="{Binding ExpanderVisibility}"
                    Command="{Binding DataContext.ToggleVisualTreeNodeExpansionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                    CommandParameter="{Binding}" />
            <Button Grid.Column="1"
                    Content="{Binding Label}"
                    Padding="6,4"
                    Margin="0"
                    Background="Transparent"
                    Foreground="{Binding RowForeground}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Left"
                    Command="{Binding DataContext.SelectVisualTreeNodeCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                    CommandParameter="{Binding}" />
          </Grid>
        </Border>
        <ItemsControl ItemsSource="{Binding Children}"
                      ItemTemplate="{StaticResource VisualTreeNodeTemplate}"
                      Visibility="{Binding ChildrenVisibility}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="InspectorSectionTemplate">
      <Border Margin="0,8,0,0"
              Background="#0B1118"
              BorderBrush="#1E4A78"
              BorderThickness="3,1,1,1"
              CornerRadius="6"
              ClipToBounds="True">
        <StackPanel>
          <Border Background="#090D13"
                  BorderBrush="#142232"
                  BorderThickness="0,0,0,1"
                  Padding="10,5">
            <TextBlock Text="{Binding Title}"
                       Foreground="#4A6880"
                       FontSize="11" />
          </Border>
          <ItemsControl ItemsSource="{Binding Properties}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#0B1118"
                        BorderBrush="#0F1A26"
                        BorderThickness="0,0,0,1"
                        Padding="10,5">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               Foreground="#4A6880"
                               FontSize="12"
                               VerticalAlignment="Top"
                               Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               Foreground="#B8D8F0"
                               FontSize="12"
                               VerticalAlignment="Top"
                               TextWrapping="Wrap" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="SourceLineNumberTemplate">
      <Border Height="{Binding LineHeight}">
        <TextBlock Text="{Binding NumberText}"
                   Foreground="#4E667C"
                   FontFamily="Consolas"
                   FontSize="{Binding FontSize}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center" />
      </Border>
    </DataTemplate>

    <Style x:Key="DiagnosticCardButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="HoverChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0"
                    Padding="0">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#132131" />
          <Setter Property="BorderBrush" Value="#294866" />
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#13253A" />
        </Trigger>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="#2A5070" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="DiagnosticCardTemplate">
      <Button Style="{StaticResource DiagnosticCardButtonStyle}"
              Padding="0"
              Margin="0"
              HorizontalContentAlignment="Stretch"
              VerticalContentAlignment="Stretch"
                Cursor="{Binding CursorText}"
                Command="{Binding DataContext.NavigateToDiagnosticCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
              CommandParameter="{Binding}">
              <Border BorderBrush="{Binding SeverityColor}"
                BorderThickness="2,0,0,0"
                Padding="8,4,10,4"
                Margin="0,0,0,1"
                  Opacity="{Binding CardOpacity}">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding CodeText}"
                         Foreground="{Binding SeverityColor}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,7,0"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding Message}"
                         Foreground="#C0CDD8"
                         FontSize="11"
                         TextWrapping="NoWrap"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="2"
                         Text="{Binding LocationText}"
                         Foreground="#3A5268"
                         FontSize="10"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right" />
            </Grid>
            <TextBlock Text="{Binding TargetDescription}"
                       Foreground="#3A5872"
                       FontSize="10"
                       Margin="0,1,0,0"
                       Visibility="{Binding TargetVisibility}" />
            <TextBlock Text="{Binding Hint}"
                       Foreground="#4A7090"
                       FontSize="10"
                       Margin="0,1,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding HintVisibility}" />
          </StackPanel>
        </Border>
      </Button>
    </DataTemplate>
  </UserControl.Resources>
  <Grid x:Name="DesignerShellRootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="20" />
      <RowDefinition Height="220" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Border Grid.Row="0"
            Background="#0D131A"
            BorderBrush="#1A2637"
            BorderThickness="0,0,0,1"
            Padding="8,5">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="NewButton"
                  Content="New"
              Command="{Binding NewCommand}"
                  Background="Transparent"
                  Foreground="#8DA1B5"
                  BorderBrush="#243342"
                  BorderThickness="1"
                  Padding="10,4"
                  Margin="0,0,3,0" />
          <Button x:Name="OpenButton"
                  Content="Open"
              Command="{Binding OpenCommand}"
                  Background="Transparent"
                  Foreground="#8DA1B5"
                  BorderBrush="#243342"
                  BorderThickness="1"
                  Padding="10,4"
                  Margin="0,0,3,0" />
          <Button x:Name="SaveButton"
                  Content="Save"
              Command="{Binding SaveCommand}"
                  Background="#0D2218"
                  Foreground="#8FD2B3"
                  BorderBrush="#1A4030"
                  BorderThickness="1"
                  Padding="10,4"
                  Margin="0,0,3,0" />
          <Button x:Name="SaveAsButton"
                  Content="Save As"
              Command="{Binding SaveAsCommand}"
                  Background="Transparent"
                  Foreground="#8DA1B5"
                  BorderBrush="#243342"
                  BorderThickness="1"
                  Padding="10,4"
                  Margin="0,0,10,0" />
          <Button x:Name="RefreshButton"
                  Content="Refresh  F5"
              Command="{Binding RefreshCommand}"
                  Background="#0A1E36"
                  Foreground="#6FB7FF"
                  BorderBrush="#163658"
                  BorderThickness="1"
                  Padding="10,4" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="14,0,8,0">
          <TextBlock Foreground="{Binding DocumentStatusForeground}"
                     Text="{Binding DocumentStatusText}" />
          <TextBlock Text="  ·  "
                     Foreground="#243342" />
          <TextBlock Foreground="{Binding ToolbarStatusForeground}"
                     Text="{Binding ToolbarStatusText}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Workflow prompt (collapsed by default, expands inline) -->
    <Border x:Name="WorkflowPromptBorder"
            Grid.Row="1"
            Background="#0B1825"
            BorderBrush="#1A2637"
            BorderThickness="0,0,0,1"
            Padding="12,8"
          Visibility="{Binding WorkflowPromptVisibility}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0">
          <TextBlock
                     Foreground="#E7EDF5"
                     FontWeight="SemiBold"
                     Text="{Binding WorkflowPrompt.Title}" />
          <TextBlock
                     Foreground="#8DA1B5"
                     Margin="0,2,0,0"
                     Text="{Binding WorkflowPrompt.Message}" />
        </StackPanel>

        <TextBox x:Name="DocumentPathTextBox"
                 Grid.Column="1"
                 Width="340"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"
                 Text="{Binding PromptPathText}"
                 TextChanged="OnDocumentPathTextChanged"
                 Background="#080F18"
                 Foreground="#D8E3EE"
                 BorderBrush="#243342"
                 BorderThickness="1"
                 Padding="8,5"
                 Visibility="{Binding WorkflowPromptPathEditorVisibility}" />

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="WorkflowPromptPrimaryButton"
                Content="{Binding WorkflowPrompt.ConfirmText}"
              Command="{Binding PromptPrimaryCommand}"
                  Background="#0D2218"
                  Foreground="#8FD2B3"
                  BorderBrush="#1A4030"
                  BorderThickness="1"
                  Padding="10,5"
                  Margin="0,0,6,0" />
          <Button x:Name="WorkflowPromptSecondaryButton"
                  Content="Discard"
              Command="{Binding PromptSecondaryCommand}"
                  Background="#201408"
                  Foreground="#D4A87A"
                  BorderBrush="#3D2808"
                  BorderThickness="1"
                  Padding="10,5"
                  Margin="0,0,6,0"
                  Visibility="{Binding WorkflowPromptDiscardVisibility}" />
          <Button x:Name="WorkflowPromptCancelButton"
                  Content="Cancel"
              Command="{Binding PromptCancelCommand}"
                  Background="Transparent"
                  Foreground="#8DA1B5"
                  BorderBrush="#243342"
                  BorderThickness="1"
                  Padding="10,5"
                  Visibility="{Binding WorkflowPromptVisibility}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main area: preview + side panels -->
    <Grid Grid.Row="2"
          Margin="8,8,8,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="320" MinWidth="220" />
      </Grid.ColumnDefinitions>

      <!-- Preview -->
      <Border Grid.Column="0"
              Background="#0D131A"
              BorderBrush="#1A2637"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  BorderBrush="#1A2637"
                  BorderThickness="0,0,0,1"
                  Padding="10,7">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="Preview"
                         Foreground="#C8D8E8"
                         FontWeight="SemiBold" />
              <TextBlock
                         Grid.Column="1"
                         Foreground="{Binding PreviewStatusForeground}"
                         VerticalAlignment="Center"
                         Text="{Binding PreviewStatusText}" />
            </Grid>
          </Border>

          <ScrollViewer x:Name="PreviewScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Grid>
              <ContentControl x:Name="PreviewHost"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Content="{Binding PreviewContent}"
                              Visibility="{Binding PreviewContentVisibility}" />
              <ContentControl HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Content="{Binding PreviewPlaceholder}"
                              ContentTemplate="{StaticResource PreviewPlaceholderTemplate}"
                              Visibility="{Binding PreviewPlaceholderVisibility}" />
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>

      <GridSplitter x:Name="PreviewDockSplitter"
                    Grid.Column="1"
                    Background="#0B0F14"
                    BorderBrush="#1E3450"
                    BorderThickness="1,0,1,0"
                    Margin="5,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext" />

      <!-- Side panels: Visual Tree, Inspector -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="6" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Visual Tree -->
        <Border Grid.Row="0"
                Background="#0D131A"
                BorderBrush="#1A2637"
                BorderThickness="1"
                CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="#1A2637"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
              <StackPanel>
                <TextBlock Text="Visual Tree"
                           Foreground="#C8D8E8"
                           FontWeight="SemiBold" />
                <TextBlock
                           Foreground="#4A6880"
                           FontSize="12"
                           Margin="0,2,0,0"
                           Text="{Binding VisualTreeSummaryText}" />
              </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="6">
              <ItemsControl x:Name="VisualTreeView"
                            ItemsSource="{Binding VisualTreeRoots}"
                            ItemTemplate="{StaticResource VisualTreeNodeTemplate}" />
            </ScrollViewer>
          </Grid>
        </Border>

        <!-- Inspector -->
        <Border Grid.Row="2"
                Background="#0D131A"
                BorderBrush="#1A2637"
                BorderThickness="1"
                CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="#1A2637"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
              <StackPanel>
                <TextBlock Text="Inspector"
                           Foreground="#C8D8E8"
                           FontWeight="SemiBold" />
                <TextBlock
                           Foreground="#4A6880"
                           FontSize="12"
                           Margin="0,2,0,0"
                           Text="{Binding InspectorSummaryText}" />
              </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
              <ItemsControl x:Name="InspectorPanel"
                            ItemsSource="{Binding InspectorSections}"
                            ItemTemplate="{StaticResource InspectorSectionTemplate}" />
            </ScrollViewer>
          </Grid>
        </Border>

      </Grid>
    </Grid>

    <GridSplitter x:Name="PreviewSourceSplitter"
                  Grid.Row="3"
                  Height="8"
                  Margin="8,0"
                  Background="#0B0F14"
                  BorderBrush="#1E3450"
                  BorderThickness="0,1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  ResizeDirection="Rows"
                  ResizeBehavior="PreviousAndNext" />

    <!-- Source editor + diagnostics -->
    <Border Grid.Row="4"
            Margin="8,0,8,8"
            Background="#0D131A"
            BorderBrush="#1A2637"
            BorderThickness="1"
            CornerRadius="8">
      <TabControl x:Name="EditorTabControl"
                  SelectedIndex="{Binding SelectedEditorTabIndex}"
                  Background="#0D131A"
                  Foreground="#C8D8E8"
                  HeaderBackground="#0B1118"
                  SelectedHeaderBackground="#102236"
                  BorderBrush="#1A2637"
                  BorderThickness="0"
                  HeaderPadding="14,8">
        <TabItem x:Name="SourceTab"
                 Header="Source">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="56" />
              <ColumnDefinition Width="1" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SourceLineNumberBorder"
                    Grid.Column="0"
                    Background="#0A1017"
                    ClipToBounds="True">
              <ItemsControl x:Name="SourceLineNumberPanel"
                    ItemTemplate="{StaticResource SourceLineNumberTemplate}"
                    Margin="0,10,6,0" />
            </Border>

            <Border Grid.Column="1"
                    Background="#1A2637" />

            <RichTextBox x:Name="SourceEditor"
                         Grid.Column="2"
                         TextChanged="OnSourceEditorTextChanged"
                         ViewportChanged="OnSourceEditorViewportChanged"
                         LayoutUpdated="OnSourceEditorLayoutUpdated"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#D8E3EE"
                         CaretBrush="#7FD0FF"
                         SelectionBrush="#1A4A7A"
                         Padding="10"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas" />
          </Grid>
        </TabItem>

        <TabItem x:Name="DiagnosticsTab"
                 Header="{Binding DataContext.DiagnosticsTabHeader, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="#1A2637"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
              <TextBlock x:Name="DiagnosticsSummaryText"
                         Foreground="#4A6880"
                         FontSize="12"
                         Text="{Binding DataContext.DiagnosticsSummaryText, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}" />
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
              <ItemsControl x:Name="DiagnosticsItemsControl"
                            ItemsSource="{Binding DataContext.Diagnostics, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                            ItemTemplate="{StaticResource DiagnosticCardTemplate}" />
            </ScrollViewer>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>
  </Grid>
</UserControl>
