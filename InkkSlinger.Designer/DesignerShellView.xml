<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.Designer.DesignerShellView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#18191B">
  <UserControl.Resources>
    <DataTemplate x:Key="PreviewPlaceholderTemplate">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Width="420">
        <Border Width="56"
                Height="4"
          Background="{Binding Accent}"
                Margin="0,0,0,16" />
        <TextBlock Text="{Binding Title}"
                   Foreground="#EEF1F7"
                   FontSize="24"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Body}"
             Foreground="{Binding BodyColor}"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </DataTemplate>

    <Style x:Key="DesignerRootComboBoxItemStyle"
           TargetType="{x:Type ComboBoxItem}">
      <Setter Property="Background" Value="#24272C" />
      <Setter Property="SelectedBackground" Value="#31518A" />
      <Setter Property="BorderBrush" Value="#24272C" />
      <Setter Property="Foreground" Value="#E5E7EA" />
      <Setter Property="Padding" Value="8,6,8,6" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2D33" />
          <Setter Property="BorderBrush" Value="#3C414A" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#31518A" />
          <Setter Property="BorderBrush" Value="#4A4D54" />
          <Setter Property="Foreground" Value="#EEF1F7" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DesignerRootComboBoxDropDownListStyle"
           TargetType="{x:Type ListBox}">
      <Setter Property="Background" Value="#24272C" />
      <Setter Property="Foreground" Value="#E5E7EA" />
      <Setter Property="BorderBrush" Value="#3C414A" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DesignerRootComboBoxDropDownPopupStyle"
           TargetType="{x:Type Popup}">
      <Setter Property="TitleBarHeight" Value="0" />
      <Setter Property="CanClose" Value="False" />
      <Setter Property="CanDragMove" Value="False" />
      <Setter Property="DismissOnOutsideClick" Value="True" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#3C414A" />
      <Setter Property="Background" Value="#24272C" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="DesignerRootComboBoxStyle"
           TargetType="{x:Type ComboBox}">
      <Setter Property="Background" Value="#1D1F22" />
      <Setter Property="Foreground" Value="#E5E7EA" />
      <Setter Property="BorderBrush" Value="#3C414A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,5,8,5" />
      <Setter Property="FontFamily" Value="Consolas" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="ItemContainerStyle" Value="{StaticResource DesignerRootComboBoxItemStyle}" />
      <Setter Property="DropDownListStyle" Value="{StaticResource DesignerRootComboBoxDropDownListStyle}" />
      <Setter Property="DropDownPopupStyle" Value="{StaticResource DesignerRootComboBoxDropDownPopupStyle}" />
    </Style>

    <DataTemplate x:Key="DesignerRootTemplateComboBoxItemTemplate">
      <TextBlock Text="{Binding DisplayText}"
                 TextWrapping="Wrap"
                 Foreground="#E5E7EA"
                 FontFamily="Consolas"
                 FontSize="12" />
    </DataTemplate>

    <DataTemplate x:Key="VisualTreeNodeTemplate">
      <Border Margin="{Binding IndentMargin}"
              Background="{Binding RowBackground}"
              BorderBrush="{Binding RowBorderBrush}"
              BorderThickness="0,0,0,1"
              CornerRadius="4">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0"
                  Content="{Binding ExpandGlyph}"
                  Width="20"
                  Height="20"
                  Padding="0"
                  Margin="0,0,6,0"
                  Background="Transparent"
                   Foreground="#C7CBD3"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  Visibility="{Binding ExpanderVisibility}"
                  Command="{Binding DataContext.ToggleVisualTreeNodeExpansionCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                  CommandParameter="{Binding}" />
          <Button Grid.Column="1"
                  Content="{Binding Label}"
                  Padding="6,4"
                  Margin="0"
                  Background="Transparent"
                  Foreground="{Binding RowForeground}"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  HorizontalContentAlignment="Left"
                  Command="{Binding DataContext.SelectVisualTreeNodeCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                  CommandParameter="{Binding}" />
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="InspectorSectionTemplate">
      <Border Margin="0,8,0,0"
              Background="#1D1F22"
              BorderBrush="#31518A"
              BorderThickness="3,1,1,1"
              CornerRadius="6"
              ClipToBounds="True">
        <StackPanel>
          <Border Background="#1D1F22"
                  BorderBrush="#2B2D31"
                  BorderThickness="0,0,0,1"
                  Padding="10,5">
            <TextBlock Text="{Binding Title}"
                       Foreground="#8E939E"
                       FontSize="11" />
          </Border>
          <ItemsControl ItemsSource="{Binding Properties}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel Orientation="Vertical"
                                        IsVirtualizing="True"
                                        VirtualizationMode="Recycling"
                                        CacheLength="1"
                                        CacheLengthUnit="Page" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#1D1F22"
                        BorderBrush="#2B2D31"
                        BorderThickness="0,0,0,1"
                        Padding="10,5">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               Foreground="#8E939E"
                               FontSize="12"
                               VerticalAlignment="Top"
                               Margin="0,0,12,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               Foreground="#C7CBD3"
                               FontSize="12"
                               VerticalAlignment="Top"
                               TextWrapping="Wrap" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </DataTemplate>

    <Style x:Key="DesignerToolbarButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="#1D1F22" />
      <Setter Property="Foreground" Value="#E5E7EA" />
      <Setter Property="BorderBrush" Value="#4A4D54" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,4" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2D33" />
          <Setter Property="BorderBrush" Value="#6A6F7A" />
          <Setter Property="Foreground" Value="#FFFFFF" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DiagnosticCardButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="HoverChrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="0"
                    Padding="0">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#24272C" />
          <Setter Property="BorderBrush" Value="#3C414A" />
        </Trigger>
        <Trigger Property="IsPressed" Value="True">
          <Setter Property="Background" Value="#24272C" />
        </Trigger>
        <Trigger Property="IsFocused" Value="True">
          <Setter Property="BorderBrush" Value="#4A4D54" />
          <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="DiagnosticCardTemplate">
      <Button Style="{StaticResource DiagnosticCardButtonStyle}"
              Padding="0"
              Margin="0"
              HorizontalContentAlignment="Stretch"
              VerticalContentAlignment="Stretch"
                Cursor="{Binding CursorText}"
                Command="{Binding DataContext.NavigateToDiagnosticCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
              CommandParameter="{Binding}">
              <Border BorderBrush="{Binding SeverityColor}"
                BorderThickness="2,0,0,0"
                Padding="8,4,10,4"
                Margin="0,0,0,1"
                  Opacity="{Binding CardOpacity}">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding CodeText}"
                         Foreground="{Binding SeverityColor}"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Margin="0,0,7,0"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding Message}"
                         Foreground="#E5E7EA"
                         FontSize="11"
                         TextWrapping="NoWrap"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="2"
                         Text="{Binding LocationText}"
                         Foreground="#8E939E"
                         FontSize="10"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right" />
            </Grid>
            <TextBlock Text="{Binding TargetDescription}"
                       Foreground="#8E939E"
                       FontSize="10"
                       Margin="0,1,0,0"
                       Visibility="{Binding TargetVisibility}" />
            <TextBlock Text="{Binding Hint}"
                       Foreground="#8E939E"
                       FontSize="10"
                       Margin="0,1,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding HintVisibility}" />
          </StackPanel>
        </Border>
      </Button>
    </DataTemplate>
  </UserControl.Resources>
  <Grid x:Name="DesignerShellRootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="4" />
      <RowDefinition Height="220" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Border Grid.Row="0"
            Background="#1D1F22"
            BorderBrush="#2B2D31"
            BorderThickness="0,0,0,1"
            Padding="6,4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="SaveButton"
                  Content="Save"
              Command="{Binding SaveCommand}"
                  Style="{StaticResource DesignerToolbarButtonStyle}"
                  Margin="0,0,3,0" />
          <Button x:Name="RefreshButton"
                  Content="Refresh  F5"
              Command="{Binding RefreshCommand}"
                  Style="{StaticResource DesignerToolbarButtonStyle}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="14,0,8,0">
          <TextBlock Foreground="{Binding DocumentStatusForeground}"
                     Text="{Binding DocumentStatusText}" />
          <TextBlock Text="  ·  "
                     Foreground="#2B2D31" />
          <TextBlock Foreground="{Binding ToolbarStatusForeground}"
                     Text="{Binding ToolbarStatusText}" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="12,0,0,0">
          <TextBlock Text="New root"
                     Foreground="#8E939E"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <ComboBox x:Name="RootTemplateComboBox"
                    Style="{StaticResource DesignerRootComboBoxStyle}"
                    Width="190"
                    MaxDropDownHeight="260"
                    DisplayMemberPath="DisplayText"
                    ItemTemplate="{StaticResource DesignerRootTemplateComboBoxItemTemplate}"
                    ItemsSource="{Binding RootTemplates}"
                    SelectedItem="{Binding SelectedRootTemplate, Mode=TwoWay}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Workflow prompt (collapsed by default, expands inline) -->
    <Border x:Name="WorkflowPromptBorder"
            Grid.Row="1"
            Background="#24272C"
            BorderBrush="#2B2D31"
            BorderThickness="0,0,0,1"
            Padding="12,8"
          Visibility="{Binding WorkflowPromptVisibility}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0">
          <TextBlock
                     Foreground="#EEF1F7"
                     FontWeight="SemiBold"
                     Text="{Binding WorkflowPrompt.Title}" />
          <TextBlock
                     Foreground="#C7CBD3"
                     Margin="0,2,0,0"
                     Text="{Binding WorkflowPrompt.Message}" />
        </StackPanel>

        <TextBox x:Name="DocumentPathTextBox"
                 Grid.Column="1"
                 Width="340"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"
                 Text="{Binding PromptPathText}"
                 Background="#1D1F22"
                 Foreground="#E5E7EA"
                 BorderBrush="#3C414A"
                 BorderThickness="1"
                 Padding="8,5"
                 Visibility="{Binding WorkflowPromptPathEditorVisibility}" />

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="WorkflowPromptPrimaryButton"
                Content="{Binding WorkflowPrompt.ConfirmText}"
              Command="{Binding PromptPrimaryCommand}"
                  Background="#0D2218"
                  Foreground="#8FD2B3"
                  BorderBrush="#1A4030"
                  BorderThickness="1"
                  Padding="10,5"
                  Margin="0,0,6,0" />
          <Button x:Name="WorkflowPromptCancelButton"
                  Content="Cancel"
              Command="{Binding PromptCancelCommand}"
                  Background="Transparent"
                  Foreground="#C7CBD3"
                  BorderBrush="#3C414A"
                  BorderThickness="1"
                  Padding="10,5"
                  Visibility="{Binding WorkflowPromptVisibility}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main area: preview + side panels -->
    <Grid Grid.Row="2"
          Margin="4,4,4,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="210" />
        <ColumnDefinition Width="4" />
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition Width="4" />
        <ColumnDefinition Width="320" MinWidth="220" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#1D1F22"
              BorderBrush="#2B2D31"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  BorderBrush="#2B2D31"
                  BorderThickness="0,0,0,1"
                  Padding="10,7">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Project Explorer"
                           Foreground="#C7CBD3"
                           FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Start"
                        Command="{Binding BackToStartCommand}"
                        Background="Transparent"
                        Foreground="#8E939E"
                        BorderBrush="#3C414A"
                        BorderThickness="1"
                        Padding="7,3" />
              </Grid>
              <TextBlock Text="{Binding ProjectDisplayName}"
                         Foreground="#8E939E"
                         FontSize="12"
                         Margin="0,2,0,0" />
            </StackPanel>
          </Border>

          <TreeView x:Name="ProjectExplorerTree"
                    Grid.Row="1"
                    Background="#18191B"
                    BorderBrush="#18191B"
                    BorderThickness="0"
                    Foreground="#E5E7EA"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Padding="6" />
        </Grid>
      </Border>

      <GridSplitter x:Name="ProjectExplorerSplitter"
                    Grid.Column="1"
                    Cursor="SizeWE"
                    Background="#18191B"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Margin="1,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext" />

      <!-- Preview -->
      <Border Grid.Column="2"
              Background="#1D1F22"
              BorderBrush="#2B2D31"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  BorderBrush="#2B2D31"
                  BorderThickness="0,0,0,1"
                  Padding="10,7">
            <TextBlock Text="Preview"
                       Foreground="#C7CBD3"
                       FontWeight="SemiBold" />
          </Border>

          <ScrollViewer x:Name="PreviewScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Grid>
              <ContentControl x:Name="PreviewHost"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Content="{Binding PreviewContent}"
                              Visibility="{Binding PreviewContentVisibility}" />
              <ContentControl HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Content="{Binding PreviewPlaceholder}"
                              ContentTemplate="{StaticResource PreviewPlaceholderTemplate}"
                              Visibility="{Binding PreviewPlaceholderVisibility}" />
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>

      <GridSplitter x:Name="PreviewDockSplitter"
                    Grid.Column="3"
                    Cursor="SizeWE"
                    Background="#18191B"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Margin="1,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext" />

      <!-- Side panels: Visual Tree, Inspector -->
      <Grid Grid.Column="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="3" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Visual Tree -->
        <Border Grid.Row="0"
                Background="#1D1F22"
                BorderBrush="#2B2D31"
                BorderThickness="1"
                CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="#2B2D31"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
              <StackPanel>
                <TextBlock Text="Visual Tree"
                           Foreground="#C7CBD3"
                           FontWeight="SemiBold" />
                <TextBlock
                           Foreground="#8E939E"
                           FontSize="12"
                           Margin="0,2,0,0"
                           Text="{Binding VisualTreeSummaryText}" />
              </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="6">
              <ItemsControl x:Name="VisualTreeView"
                            ItemsSource="{Binding VisualTreeNodes}"
                            ItemTemplate="{StaticResource VisualTreeNodeTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical"
                                            IsVirtualizing="True"
                                            VirtualizationMode="Recycling"
                                            CacheLength="1"
                                            CacheLengthUnit="Page" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <!-- Inspector -->
        <Border Grid.Row="2"
                Background="#1D1F22"
                BorderBrush="#2B2D31"
                BorderThickness="1"
                CornerRadius="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    BorderBrush="#2B2D31"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
              <StackPanel>
                <TextBlock Text="Inspector"
                           Foreground="#C7CBD3"
                           FontWeight="SemiBold" />
                <TextBlock
                           Foreground="#8E939E"
                           FontSize="12"
                           Margin="0,2,0,0"
                           Text="{Binding InspectorSummaryText}" />
              </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
              <ItemsControl x:Name="InspectorPanel"
                            ItemsSource="{Binding InspectorSections}"
                            ItemTemplate="{StaticResource InspectorSectionTemplate}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel Orientation="Vertical"
                                            IsVirtualizing="True"
                                            VirtualizationMode="Recycling"
                                            CacheLength="1"
                                            CacheLengthUnit="Page" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

      </Grid>
    </Grid>

    <GridSplitter x:Name="PreviewSourceSplitter"
                  Grid.Row="3"
                  Height="4"
                  Cursor="SizeNS"
                  Margin="2,0"
                  Background="#18191B"
                  BorderBrush="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  ResizeDirection="Rows"
                  ResizeBehavior="PreviousAndNext" />

    <!-- Source editor + diagnostics -->
    <Border Grid.Row="4"
            Margin="4,0,4,4"
            Background="#1D1F22"
            BorderBrush="#2B2D31"
            BorderThickness="1"
            CornerRadius="8">
        <TabControl x:Name="EditorTabControl"
                    SelectedIndex="{Binding SelectedEditorTabIndex}"
                    Background="#1D1F22"
                    Foreground="#C7CBD3"
                    HeaderBackground="#18191B"
                    SelectedHeaderBackground="#1D1F22"
                    BorderBrush="#2B2D31"
                    BorderThickness="0"
                    HeaderPadding="14,8">
          <TabItem x:Name="SourceTab"
                   Header="Source">
            <DesignerSourceEditorView x:Name="SourceEditorPane"
                                      SourceText="{Binding SourceText}"
                                      NavigationRequest="{Binding SourceNavigationRequest}" />
          </TabItem>

          <TabItem x:Name="AppResourcesTab"
                   Header="App Resources">
            <DesignerSourceEditorView x:Name="AppResourcesEditorPane"
                                      SourceText="{Binding AppResourcesText}"
                                      NavigationRequest="{Binding AppResourcesNavigationRequest}" />
          </TabItem>

          <TabItem x:Name="DiagnosticsTab"
                   Header="{Binding DiagnosticsTabHeader}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0"
                      BorderBrush="#2B2D31"
                      BorderThickness="0,0,0,1"
                      Padding="10,7">
                <TextBlock x:Name="DiagnosticsSummaryText"
                           Foreground="#8E939E"
                           FontSize="12"
                           Text="{Binding DiagnosticsSummaryText}" />
              </Border>
              <ScrollViewer Grid.Row="1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Padding="6">
                <ItemsControl x:Name="DiagnosticsItemsControl"
                              ItemsSource="{Binding Diagnostics}"
                              ItemTemplate="{StaticResource DiagnosticCardTemplate}" />
              </ScrollViewer>
            </Grid>
          </TabItem>
        </TabControl>
    </Border>
  </Grid>
</UserControl>
