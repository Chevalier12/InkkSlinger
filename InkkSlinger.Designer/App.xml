<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <ResourceDictionary>
      <Color x:Key="DesignerPanelBackground">#1D1F22</Color>
      <Color x:Key="DesignerInputBackground">#1D1F22</Color>
      <Color x:Key="DesignerPopupBackground">#24272C</Color>
      <Color x:Key="DesignerPopupItemHoverBackground">#2A2D33</Color>
      <Color x:Key="DesignerPopupItemSelectedBackground">#31518A</Color>
      <Color x:Key="DesignerChromeBorder">#2B2D31</Color>
      <Color x:Key="DesignerInputBorder">#3C414A</Color>
      <Color x:Key="DesignerPopupBorder">#3C414A</Color>
      <Color x:Key="DesignerTextPrimary">#E5E7EA</Color>
      <Color x:Key="DesignerTextMuted">#8E939E</Color>

      <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="#18191B" />
        <Setter Property="Foreground" Value="#EEF1F7" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
      </Style>

      <!-- ═══════════════════════════════════════════════════════════════ -->
      <!-- SCROLLBAR — slim dark-theme bars matching the designer palette -->
      <!-- ═══════════════════════════════════════════════════════════════ -->
      <Style TargetType="{x:Type ScrollBar}">
        <!-- Track background: barely-visible dark trough -->
        <Setter Property="Background" Value="#1D1F22" />
        <!-- Thumb fill: neutral gray matching #2B2D31 border palette -->
        <Setter Property="Foreground" Value="#2B2D31" />
        <!-- No border on track or thumb -->
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <!-- Vertical bar: 8 px wide -->
        <Setter Property="Width" Value="8" />
        <Style.Triggers>
          <Trigger Property="Orientation" Value="Horizontal">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="8" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- ══════════════════════════════════════════════════════════════ -->
      <!-- SCROLLVIEWER — transparent host, uses slim ScrollBarThickness -->
      <!-- ══════════════════════════════════════════════════════════════ -->
      <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollBarThickness" Value="8" />
      </Style>

      <Style TargetType="{x:Type Popup}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource DesignerPopupBorder}" />
        <Setter Property="Background" Value="{StaticResource DesignerPopupBackground}" />
        <Setter Property="Padding" Value="0" />
      </Style>

      <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource DesignerPopupBackground}" />
        <Setter Property="Foreground" Value="{StaticResource DesignerTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource DesignerPopupBorder}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
      </Style>

      <Style x:Key="DesignerComboBoxItemStyle"
             TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="{StaticResource DesignerPopupBackground}" />
        <Setter Property="SelectedBackground" Value="{StaticResource DesignerPopupItemSelectedBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource DesignerPopupBackground}" />
        <Setter Property="Foreground" Value="{StaticResource DesignerTextPrimary}" />
        <Setter Property="Padding" Value="8,6,8,6" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="{StaticResource DesignerPopupItemHoverBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource DesignerPopupBorder}" />
          </Trigger>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="{StaticResource DesignerPopupItemSelectedBackground}" />
            <Setter Property="BorderBrush" Value="#4A4D54" />
            <Setter Property="Foreground" Value="#EEF1F7" />
          </Trigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="DesignerInspectorComboBoxStyle"
             TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{StaticResource DesignerInputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource DesignerTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource DesignerInputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5,8,5" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource DesignerComboBoxItemStyle}" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>