<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.Designer.DesignerSourceLineNumberGutterView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../InkkSlinger.UI/Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../InkkSlinger.UI/Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
  <Border x:Name="LineNumberBorder"
          Background="#0A1017"
          ClipToBounds="True">
    <DesignerSourceLineNumberPresenter x:Name="LineNumberPanel"
                                       Margin="0,10,6,0"
                                       FontFamily="Consolas"
                                       LineForeground="#4A6880" />
  </Border>
</UserControl>