<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.Designer.DesignerHierarchyView">
  <Border Background="#18191B"
          BorderBrush="#2B2D31"
          BorderThickness="0">
    <ScrollViewer x:Name="HierarchyScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  PanningMode="Both"
                  Padding="24">
      <DesignerHierarchyWorkspaceCanvas x:Name="HierarchyCanvas"
                                        Background="#18191B" />
    </ScrollViewer>
  </Border>
</UserControl>
