<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ComboBoxView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: ComboBox" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="ComboBox is a Selector that shows a single selected item and expands a popup ListBox on click. SelectedIndex and SelectedItem track the current choice. SelectionChanged is a bubbling routed event fired whenever the selection changes." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: basic usage, disabled, MaxDropDownHeight -->
            <StackPanel Grid.Column="0">

              <!-- Basic usage -->
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Basic usage" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Click the ComboBox to open the popup ListBox. Selecting an item closes the dropdown and updates SelectedIndex. The second item is pre-selected below." />

                  <ComboBox x:Name="BasicCombo" HorizontalAlignment="Stretch" />
                </StackPanel>
              </Border>

              <!-- Disabled -->
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Disabled" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="IsEnabled=False suppresses pointer interaction and dims the control. The dropdown cannot be opened." />

                  <ComboBox x:Name="DisabledCombo" HorizontalAlignment="Stretch" IsEnabled="False" />
                </StackPanel>
              </Border>

              <!-- MaxDropDownHeight -->
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="MaxDropDownHeight" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="MaxDropDownHeight caps the popup height and the inner ListBox becomes scrollable when items overflow. Default is 220. The combo below has 10 items constrained to 110." />

                  <ComboBox x:Name="TallCombo" HorizontalAlignment="Stretch" />
                </StackPanel>
              </Border>

            </StackPanel>

            <!-- Right column: selection feedback, custom colors -->
            <StackPanel Grid.Column="2">

              <!-- Selection feedback -->
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="SelectionChanged event" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="SelectionChanged fires as a bubbling RoutedEvent. The event args carry AddedItems and RemovedItems lists. The readout below updates on every selection." />

                  <ComboBox x:Name="FeedbackCombo" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                  <TextBlock x:Name="SelectionIndexLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             Text="SelectedIndex: —" />
                  <TextBlock x:Name="SelectionValueLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             Text="Selected value: —" />
                  <TextBlock x:Name="SelectionChangedCountLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="SelectionChanged fired: 0" />
                </StackPanel>
              </Border>

              <!-- Custom colors -->
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Custom colors" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Background, Foreground, BorderBrush, and BorderThickness are all settable per-instance. The two combos below show an accent and a subdued variant." />

                  <ComboBox x:Name="AccentCombo" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                  <ComboBox x:Name="SubduedCombo" HorizontalAlignment="Stretch" />
                </StackPanel>
              </Border>

            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
