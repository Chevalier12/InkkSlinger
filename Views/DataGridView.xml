<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.DataGridView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid x:Name="DataGridViewRootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border x:Name="DataGridViewHeaderBorder"
            Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <Label Content="Control Demo: DataGrid Workbench"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 FontSize="18"
                 FontWeight="SemiBold" />
          <TextBlock Text="A richer validation surface for sorting, extended selection, row details, clipboard export, and viewport behavior in the same layout."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="{StaticResource OrangePrimaryBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <Label Content="Interactive Table"
                 Foreground="{StaticResource OrangePrimaryBrush}"
                 FontWeight="SemiBold" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Border x:Name="DataGridViewBodyBorder"
              Grid.Column="0"
              Background="{StaticResource DarkSurfaceBrush}"
              BorderBrush="{StaticResource DarkBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Label Content="Live demo grid"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="15"
                     FontWeight="SemiBold" />
              <TextBlock Text="This page keeps the real sample in view while turning on more of the runtime surface than the old bare host did."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,3,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{StaticResource DarkBgBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,6"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">
              <Label Content="Sort • Select • Scroll"
                     Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>
          </Grid>

          <DataGrid x:Name="DemoGrid"
                    Grid.Row="1"
                    Margin="0,12,0,12"
                    Width="Auto"
                    Height="Auto"
                    MinWidth="520"
                    MinHeight="300"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutoGenerateColumns="False"
                    HeadersVisibility="All"
                    SelectionMode="Extended"
                    SelectionUnit="FullRow"
                    ClipboardCopyMode="IncludeHeader"
                    CanUserReorderColumns="True"
                    CanUserResizeColumns="True"
                    FrozenColumnCount="1"
                    RowHeaderWidth="52"
                    ColumnHeaderHeight="32"
                    RowDetailsVisibilityMode="VisibleWhenSelected"
                    ItemsSource="{Binding Path=DemoRows}">
            <DataGrid.Columns>
              <DataGridColumn Header="Ticket" BindingPath="Ticket" Width="96" MinWidth="72" />
              <DataGridColumn Header="Name" BindingPath="Name" Width="160" MinWidth="120" />
              <DataGridColumn Header="Team" BindingPath="Team" Width="150" MinWidth="120" />
              <DataGridColumn Header="Priority" BindingPath="Priority" Width="110" MinWidth="90" />
              <DataGridColumn Header="Status" BindingPath="Status" Width="120" MinWidth="96" />
            </DataGrid.Columns>
            <DataGrid.RowDetailsTemplate>
              <DataTemplate>
                <Border Background="#131C28"
                        BorderBrush="#456384"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,4,0,0">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal">
                      <Label Content="Selected work item"
                             Foreground="#D7EBFC"
                             FontWeight="SemiBold" />
                      <Label Content="{Binding Path=Ticket}"
                             Foreground="#D7EBFC"
                             FontWeight="SemiBold"
                             Margin="6,0,0,0" />
                      <Label Content="{Binding Path=Name}"
                             Foreground="#D7EBFC"
                             FontWeight="SemiBold"
                             Margin="6,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding Path=Team}"
                               Foreground="#A6BFD6"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Path=Priority}"
                               Foreground="#A6BFD6"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Path=Status}"
                               Foreground="#A6BFD6"
                               Margin="0,2,0,0" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </DataGrid.RowDetailsTemplate>
          </DataGrid>

          <Border Grid.Row="2"
                  Background="{StaticResource DarkBgBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="10">
            <TextBlock Text="The hosted grid is stretched to behave like a real workspace surface rather than a thumbnail. Regression tests still guard header sorting, viewport width, and bottom-of-list scrolling." 
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
          </Border>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,10">
            <StackPanel>
              <Label Content="Why this view exists"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontWeight="SemiBold" />
              <TextBlock Text="The old page only framed the sample. This version keeps the production DataGrid front-and-center while surfacing the behaviors that matter during parity work."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,10">
            <StackPanel>
              <Label Content="What is turned on"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontWeight="SemiBold" />
              <TextBlock Text="Extended multi-selection, row headers, frozen first column, row details on full-row selection, clipboard headers, and column reordering are all enabled here."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,8" />
              <Label Content="The blue lane on the far left is the row header; Ticket is the first real data column."
                     Foreground="{StaticResource TextSecondaryBrush}" />
              <Label Content="• Click a row header to expose row details." Foreground="{StaticResource TextSecondaryBrush}" />
              <Label Content="• Sort with the column headers and confirm the viewport stays stable." Foreground="{StaticResource TextSecondaryBrush}" />
              <Label Content="• Use Ctrl+A / Ctrl+C to exercise bulk selection and clipboard export." Foreground="{StaticResource TextSecondaryBrush}" />
              <Label Content="• Drag the Name or Status column to verify reorder chrome and frozen-column behavior." Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">
            <StackPanel>
              <Label Content="Regression focus"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontWeight="SemiBold" />
              <TextBlock Text="This page is meant to make selection, sorting, and scrolling bugs obvious in one screen instead of forcing agents to hop between tiny isolated probes."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,4,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>






