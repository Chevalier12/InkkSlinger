<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#0F1622"
             BorderBrush="#2E4A66"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#162334" BorderBrush="#355474" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Text="Control Demo: Control" Foreground="#E8F5FF" />
    </Border>

    <Border Grid.Row="1" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
      <ContentControl x:Name="DemoHost" />
    </Border>
  </Grid>
</UserControl>

