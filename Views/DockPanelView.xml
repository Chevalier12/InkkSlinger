<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.DockPanelView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid x:Name="DockPanelViewRootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Control Demo: DockPanel Workbench"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
          <TextBlock Text="A dedicated shell-layout demo for edge docking, declaration order, and the LastChildFill handoff that determines whether the final child fills or keeps docking."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#8FD3FF"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="Edges • Order • Fill"
                     Foreground="#8FD3FF"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="DockPanelViewContentGrid"
          Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="0" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Border x:Name="DockPanelViewBodyBorder"
              Grid.Row="0"
              Grid.Column="0"
              Background="{StaticResource DarkSurfaceBrush}"
              BorderBrush="{StaticResource DarkBorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Text="Live shell preview"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="The preview uses a real DockPanel tree instead of a generic sample host, so docked rails and the final fill handoff are visible as you change the panel state."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,3,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{StaticResource DarkBgBrush}"
                    BorderBrush="{StaticResource DarkBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,6"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center">
              <TextBlock Text="WPF-style shell composition"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </Border>
          </Grid>

          <Border Grid.Row="1"
                  Background="{StaticResource DarkBgBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="12"
                  Margin="0,12,0,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0"
                         Text="Toggle fill behavior, widen the left rail, or make the top and bottom chrome taller to watch the same DockPanel react without swapping layouts or controls."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,0,12,0" />

              <CheckBox x:Name="LastChildFillCheckBox"
                        Grid.Column="1"
                        Content="Last child fills"
                        IsChecked="True"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />

              <CheckBox x:Name="WideNavigationCheckBox"
                        Grid.Column="2"
                        Content="Wide nav rail"
                        IsChecked="False"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />

              <CheckBox x:Name="TallChromeCheckBox"
                        Grid.Column="3"
                        Content="Tall chrome"
                        IsChecked="False"
                        VerticalAlignment="Center" />
            </Grid>
          </Border>

            <Border x:Name="DockWorkbenchStageBorder"
              Grid.Row="2"
                  Background="{StaticResource DarkBgBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,12">
                <ScrollViewer x:Name="DockWorkbenchScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                  <DockPanel x:Name="DockWorkbenchPanel"
                 MinHeight="360"
                 LastChildFill="True">
              <Border x:Name="TopRailCard"
                      DockPanel.Dock="Top"
                      Background="#1A3345"
                      BorderBrush="#3E6B8B"
                      BorderThickness="0,0,0,1"
                      CornerRadius="6,6,0,0"
                      Padding="16,12,16,12"
                      Margin="0,0,0,10">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Top rail"
                               Foreground="#E4F5FF"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TopRailSummaryText"
                               Text="Top and bottom edges typically host shell chrome such as title areas, tabs, or status surfaces."
                               Foreground="#BFDCEE"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>

                  <Border Grid.Column="1"
                          Background="#173043"
                          BorderBrush="#5B8BAA"
                          BorderThickness="1"
                          CornerRadius="12"
                          Padding="10,4"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center">
                    <TextBlock x:Name="TopRailBadgeText"
                               Text="Primary chrome"
                               Foreground="#D8F2FF"
                               TextWrapping="Wrap" />
                  </Border>
                </Grid>
              </Border>

              <Border x:Name="BottomRailCard"
                      DockPanel.Dock="Bottom"
                      Background="#1F2A17"
                      BorderBrush="#4D6E39"
                      BorderThickness="1,1,1,0"
                      CornerRadius="0,0,6,6"
                      Padding="14,8,14,8"
                      Margin="0,10,0,0">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0"
                             x:Name="BottomRailSummaryText"
                             Text="Bottom rail can reserve persistent status or command surfaces without changing the center host."
                             Foreground="#D9EED0"
                             TextWrapping="Wrap" />

                  <Border Grid.Column="1"
                          Background="#26361C"
                          BorderBrush="#5F8446"
                          BorderThickness="1"
                          CornerRadius="12"
                          Padding="10,4"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center">
                    <TextBlock x:Name="BottomRailBadgeText"
                               Text="Status lane"
                               Foreground="#E7F7DE"
                               TextWrapping="Wrap" />
                  </Border>
                </Grid>
              </Border>

              <Border x:Name="LeftRailCard"
                      DockPanel.Dock="Left"
                      Width="176"
                      ClipToBounds="True"
                      Background="#241D35"
                      BorderBrush="#66508A"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="12"
                      Margin="0,0,10,0">
                <StackPanel>
                  <TextBlock Text="Left rail"
                             Foreground="#F1E6FF"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="LeftRailSummaryText"
                             Text="Navigation or a tool rail usually docks first so the rest of the shell can size around it."
                             Foreground="#D3C0EE"
                             TextWrapping="Wrap"
                             Margin="0,4,0,10" />

                    <Border x:Name="LeftRailInboxCard"
                      Background="#2F2444"
                          BorderBrush="#6F5C96"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,8">
                    <TextBlock Text="Inbox"
                               Foreground="#F7F0FF"
                               TextWrapping="Wrap" />
                  </Border>

                    <Border x:Name="LeftRailPinnedViewsCard"
                      Background="#2F2444"
                          BorderBrush="#6F5C96"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,8">
                    <TextBlock Text="Pinned views"
                               Foreground="#F7F0FF"
                               TextWrapping="Wrap" />
                  </Border>

                    <Border x:Name="LeftRailFiltersCard"
                      Background="#2F2444"
                          BorderBrush="#6F5C96"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10">
                    <TextBlock Text="Search filters"
                               Foreground="#F7F0FF"
                               TextWrapping="Wrap" />
                  </Border>
                </StackPanel>
              </Border>

              <Border x:Name="RightRailCard"
                      DockPanel.Dock="Right"
                      Width="188"
                      ClipToBounds="True"
                      Background="#352515"
                      BorderBrush="#8B6841"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="12"
                      Margin="10,0,0,0">
                <StackPanel>
                  <TextBlock Text="Right rail"
                             Foreground="#FFF0DE"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="RightRailSummaryText"
                             Text="Inspector content keeps its own edge while the center stays focused on the main workspace."
                             Foreground="#E8D0B1"
                             TextWrapping="Wrap"
                             Margin="0,4,0,10" />

                    <Border x:Name="RightRailMetadataCard"
                      Background="#402C18"
                          BorderBrush="#997346"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10"
                          Margin="0,0,0,8">
                    <TextBlock Text="Selection metadata"
                               Foreground="#FFF2E1"
                               TextWrapping="Wrap" />
                  </Border>

                    <Border x:Name="RightRailDiagnosticsCard"
                      Background="#402C18"
                          BorderBrush="#997346"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10">
                    <TextBlock Text="Pinned diagnostics"
                               Foreground="#FFF2E1"
                               TextWrapping="Wrap" />
                  </Border>
                </StackPanel>
              </Border>

              <Border x:Name="CenterCanvasCard"
                      DockPanel.Dock="Left"
                      Width="280"
                      ClipToBounds="True"
                      Background="#152431"
                      BorderBrush="#48708B"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="16">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0"
                             x:Name="CenterHeadlineText"
                             Text="Center workspace"
                             Foreground="#E5F6FF"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />

                  <TextBlock Grid.Row="1"
                             x:Name="CenterSummaryText"
                             Text="With LastChildFill on, the final child consumes the remaining rectangle after the four edge lanes finish docking."
                             Foreground="#C3DFEE"
                             TextWrapping="Wrap"
                             Margin="0,6,0,12" />

                  <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                        <Border x:Name="CenterModeCard"
                          Grid.Row="0"
                            Background="#1B3142"
                            BorderBrush="#4D7591"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,8">
                      <TextBlock x:Name="CenterModeText"
                                 Text="Fill mode active"
                                 Foreground="#E5F6FF"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                    </Border>

                        <Border x:Name="CenterBehaviorCard"
                          Grid.Row="1"
                            Background="#1B3142"
                            BorderBrush="#4D7591"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,8">
                      <TextBlock x:Name="CenterBehaviorText"
                                 Text="The workspace expands to the leftover rectangle created by the docked rails."
                                 Foreground="#D3EAF7"
                                 TextWrapping="Wrap" />
                    </Border>

                        <Border x:Name="CenterTelemetryCard"
                          Grid.Row="2"
                            Background="#10202B"
                            BorderBrush="#355A72"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                      <TextBlock x:Name="CenterTelemetryText"
                                 Text="Resize the catalog pane or toggle options to inspect the arranged workspace bounds."
                                 Foreground="#C3DFEE"
                                 TextWrapping="Wrap" />
                    </Border>
                  </Grid>

                    <Border x:Name="CenterFooterBadge"
                      Grid.Row="3"
                          Background="#143141"
                          BorderBrush="#4A7693"
                          BorderThickness="1"
                          CornerRadius="14"
                          Padding="10,4"
                          Margin="0,12,0,0"
                          HorizontalAlignment="Left">
                    <TextBlock x:Name="CenterFooterText"
                               Text="Declared last so it can fill by default"
                               Foreground="#E5F6FF"
                               TextWrapping="Wrap" />
                  </Border>
                </Grid>
              </Border>
            </DockPanel>
            </ScrollViewer>
          </Border>

            <Border x:Name="DockOrderBorder"
              Grid.Row="3"
                  Background="{StaticResource DarkBgBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0"
                      Background="#143141"
                      BorderBrush="#4A7693"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="10,4"
                      Margin="0,0,12,0"
                      VerticalAlignment="Top">
                <TextBlock Text="Child order"
                           Foreground="#DDF3FF"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
              </Border>

              <TextBlock Grid.Column="1"
                         x:Name="DockOrderSummaryText"
                         Text="The workbench declares children as Top, Bottom, Left, Right, then Center. Toggle LastChildFill off to see the final child stop filling and instead dock using its own attached edge."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <ScrollViewer x:Name="DockPanelViewInfoScrollViewer"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="What to watch"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Each child is measured and arranged in declaration order against the remaining rectangle. Edge lanes take their slice first; the final child only fills if LastChildFill remains enabled."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="Live telemetry"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="LayoutModeValueText"
                         Text="Layout mode: wide rail"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="FillBehaviorValueText"
                         Text="Fill behavior: last child expands"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="EdgeMetricsText"
                         Text="Edges: waiting for arrange telemetry"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="CenterMetricsText"
                         Text="Center: waiting for arrange telemetry"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
              <TextBlock x:Name="SequenceValueText"
                         Text="Sequence: Top -> Bottom -> Left -> Right -> Center"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12"
                  Margin="0,0,0,10">
            <StackPanel>
              <TextBlock Text="Why this panel exists"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="DockPanel is strong when the screen has framing pieces: top bars, side rails, inspectors, and a central workspace. It is weaker when you need shared measurement or arbitrary spanning, which is when Grid becomes the better fit."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>

          <Border Background="{StaticResource DarkSurfaceBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">
            <StackPanel>
              <TextBlock Text="Suggested markup pattern"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Declare edge lanes first and the main content last. Leave LastChildFill on for shell layouts, or turn it off only when the final child should keep docking like the rest of the sequence."
                         Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap"
                         Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>






