<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#0F1622"
             BorderBrush="#2E4A66"
             BorderThickness="1"
             Padding="12">
  <UserControl.Resources>
    <DataTemplate x:Key="GroupHeaderTemplate">
      <Border Background="#1A2B3E" BorderBrush="#3E6287" BorderThickness="1" Padding="6" Margin="0,6,0,2">
        <Label Text="{Binding}" Foreground="#D9EDFF" />
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#162334" BorderBrush="#355474" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Text="CollectionView Parity Demo: Sort + Filter + Group + CurrentItem" Foreground="#E8F5FF" />
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="360" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="10">
        <StackPanel>
          <Label Text="Source Edits" Foreground="#DDEFFF" />
          <TextBox x:Name="NameInput" Text="New item" Margin="0,6,0,0" />
          <TextBox x:Name="CategoryInput" Text="General" Margin="0,6,0,0" />
          <TextBox x:Name="PriorityInput" Text="1" Margin="0,6,0,0" />
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="Add Item" Click="OnAddItemClick" />
            <Button Grid.Column="2" Text="Remove Current" Click="OnRemoveCurrentClick" />
          </Grid>

          <Separator Foreground="#32516E" Margin="0,10,0,10" />
          <Label Text="Filter + Sort" Foreground="#DDEFFF" />
          <TextBox x:Name="FilterInput" TextChanged="OnFilterTextChanged" Margin="0,6,0,0" />
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="Sort Name" Click="OnSortNameClick" />
            <Button Grid.Column="2" Text="Sort Priority" Click="OnSortPriorityClick" />
          </Grid>

          <Separator Foreground="#32516E" Margin="0,10,0,10" />
          <Label Text="Grouping" Foreground="#DDEFFF" />
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="6" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="6" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="None" Click="OnGroupNoneClick" />
            <Button Grid.Column="2" Text="Category" Click="OnGroupCategoryClick" />
            <Button Grid.Column="4" Text="Priority" Click="OnGroupPriorityClick" />
          </Grid>

          <Separator Foreground="#32516E" Margin="0,10,0,10" />
          <Label Text="Current Item" Foreground="#DDEFFF" />
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="6" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="6" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="6" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Text="First" Click="OnCurrentFirstClick" />
            <Button Grid.Column="2" Text="Prev" Click="OnCurrentPrevClick" />
            <Button Grid.Column="4" Text="Next" Click="OnCurrentNextClick" />
            <Button Grid.Column="6" Text="Last" Click="OnCurrentLastClick" />
          </Grid>
          <Label Text="{Binding CurrentItemText}" Margin="0,8,0,0" Foreground="#B8D8F3" />

          <Separator Foreground="#32516E" Margin="0,10,0,10" />
          <Label Text="Event Log" Foreground="#DDEFFF" />
          <ListBox x:Name="LogList" Height="180" Margin="0,6,0,0" Background="#0A121D" BorderBrush="#2E4A66" BorderThickness="1" />
          <Button Text="Clear Log" Margin="0,8,0,0" Click="OnClearLogClick" />
        </StackPanel>
      </Border>

      <Separator Grid.Column="1" Orientation="Vertical" Foreground="#2A445D" />

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="2*" />
          <RowDefinition Height="8" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
            <StackPanel>
              <Label Text="ListBox" Foreground="#DAEDFF" />
              <ListBox x:Name="DemoListBox" Margin="0,6,0,0" />
            </StackPanel>
          </Border>
          <Separator Grid.Column="1" Orientation="Vertical" Foreground="#2A445D" />
          <Border Grid.Column="2" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
            <StackPanel>
              <Label Text="ListView" Foreground="#DAEDFF" />
              <ListView x:Name="DemoListView" Margin="0,6,0,0" />
            </StackPanel>
          </Border>
        </Grid>

        <Separator Grid.Row="1" Foreground="#2A445D" />

        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
            <StackPanel>
              <Label Text="DataGrid (header sort mutates CollectionView sort descriptors)" Foreground="#DAEDFF" />
              <DataGrid x:Name="DemoDataGrid" Margin="0,6,0,0" />
            </StackPanel>
          </Border>
          <Separator Grid.Column="1" Orientation="Vertical" Foreground="#2A445D" />
          <Border Grid.Column="2" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
            <StackPanel>
              <Label Text="GroupStyle HeaderTemplate Preview" Foreground="#DAEDFF" />
              <ItemsControl x:Name="GroupPreview" Margin="0,6,0,0">
                <ItemsControl.GroupStyle>
                  <GroupStyle HeaderTemplate="{StaticResource GroupHeaderTemplate}"
                              HeaderStringFormat="Group {0} - {1} item(s)" />
                </ItemsControl.GroupStyle>
              </ItemsControl>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Background="#162334" BorderBrush="#355474" BorderThickness="1" Padding="8" Margin="0,8,0,0">
      <Label Text="{Binding Status}" Foreground="#C7E0F6" />
    </Border>
  </Grid>
</UserControl>
