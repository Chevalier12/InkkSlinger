<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.CatchMeView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            Padding="10"
            Margin="0,0,0,8">
      <Label Text="Catch Me! Hover the orb and it dashes away."
             Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1"
            Background="#1A222D"
            BorderBrush="#355474"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
      <Canvas x:Name="Playfield"
              Background="#0F1622"
              MinHeight="220">
        <Ellipse x:Name="RunnerEllipse"
                 Width="72"
                 Height="72"
                 Fill="#FF8C00"
                 Stroke="#FFE1B3"
                 StrokeThickness="2"
                 Canvas.Left="24"
                 Canvas.Top="24" />
      </Canvas>
    </Border>
  </Grid>
</UserControl>




