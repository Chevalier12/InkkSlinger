<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#0F1622"
             BorderBrush="#2E4A66"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#162334" BorderBrush="#355474" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="180" />
        </Grid.ColumnDefinitions>
        <Label Grid.Column="0" Text="Collection Add Isolation: Shared ObservableCollection -> ListBox + ListView" Foreground="#E8F5FF" />
        <Button Grid.Column="1" Text="Add Item" Click="OnAddItemClick" Margin="8,0,0,0" />
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Label Grid.Row="0" Text="ListBox" Foreground="#DAEDFF" />
          <ListBox Grid.Row="1" x:Name="DemoListBox" Margin="0,6,0,0" />
        </Grid>
      </Border>

      <Separator Grid.Column="1" Orientation="Vertical" Foreground="#2A445D" />

      <Border Grid.Column="2" Background="#111D2D" BorderBrush="#2E4A66" BorderThickness="1" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Label Grid.Row="0" Text="ListView" Foreground="#DAEDFF" />
          <ListView Grid.Row="1" x:Name="DemoListView" Margin="0,6,0,0" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#162334" BorderBrush="#355474" BorderThickness="1" Padding="8" Margin="0,8,0,0">
      <Label Text="{Binding Status}" Foreground="#C7E0F6" />
    </Border>
  </Grid>
</UserControl>
