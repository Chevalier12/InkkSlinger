<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.ListBoxView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource DarkElevatedBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            Margin="0,0,0,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Control Demo: ListBox"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
          <TextBlock Text="A real ListBox workbench covering single selection, object-backed items, SelectedValuePath, multiple and extended selection, item templates, and virtualized scrolling."
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Column="1"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#82BE8F"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,6"
                Margin="12,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="Selection / Template / Scroll"
                     Foreground="#D8F5DE"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Background="{StaticResource DarkBgBrush}"
            BorderBrush="{StaticResource DarkBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="ListBox is the framework's core selector surface for stacked items. This page keeps the important API paths live on screen so selection behavior, item projection, styling, and scrolling can be exercised without dropping into a generic sample host." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14"
                      Margin="0,0,0,12">
                <StackPanel>
                  <Label Content="Basic single selection" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="This is the baseline ListBox flow: one item is selected at a time, clicking a row updates SelectedIndex and SelectedItem, and SelectionChanged bubbles from the control." />

                  <ListBox x:Name="BasicListBox"
                           Height="188"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           Margin="0,0,0,10" />

                  <TextBlock x:Name="BasicSelectionSummaryText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Basic selection summary"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14"
                      Margin="0,0,0,12">
                <StackPanel>
                  <Label Content="ItemsSource, DisplayMemberPath, and SelectedValuePath" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="The list below is object-backed instead of string-backed. DisplayMemberPath renders the title, while SelectedValuePath projects the numeric Id so you can verify selector state independently from the selected object instance." />

                  <ListBox x:Name="CatalogListBox"
                           Height="222"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           DisplayMemberPath="Title"
                           SelectedValuePath="Id"
                           Margin="0,0,0,10" />

                  <TextBlock x:Name="CatalogSelectionIndexText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Catalog index"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="CatalogSelectionItemText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,4,0,0"
                             Text="Catalog item"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="CatalogSelectionValueText"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             Margin="0,4,0,0"
                             Text="Catalog value"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14">
                <StackPanel>
                  <Label Content="Virtualized backlog and ScrollIntoView" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="This sample turns virtualization on and exposes ScrollIntoView through buttons so long lists can be exercised directly from the catalog. The selected item is kept visible as you jump around the backlog." />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="JumpToStartButton" Content="Jump to first" Margin="0,0,8,8" />
                    <Button x:Name="JumpToMiddleButton" Content="Jump to middle" Margin="0,0,8,8" />
                    <Button x:Name="JumpToEndButton" Content="Jump to last" Margin="0,0,0,8" />
                  </WrapPanel>

                  <ListBox x:Name="VirtualizedListBox"
                           Height="260"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           DisplayMemberPath="Label"
                           IsVirtualizing="True"
                           VerticalScrollBarVisibility="Auto"
                           LineScrollAmount="34"
                           Margin="0,0,0,10" />

                  <TextBlock x:Name="VirtualizedSummaryText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Virtualized summary"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14"
                      Margin="0,0,0,12">
                <StackPanel>
                  <Label Content="Extended selection" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Extended mode keeps the familiar desktop semantics: plain click selects one item, Ctrl toggles, Shift extends a range, and Ctrl+A selects the whole list." />

                  <ListBox x:Name="ExtendedListBox"
                           Height="236"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           SelectionMode="Extended"
                           Margin="0,0,0,10" />

                  <TextBlock x:Name="ExtendedSelectionIndicesText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Extended indices"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="ExtendedSelectionItemsText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,4,0,0"
                             Text="Extended items"
                             TextWrapping="Wrap" />
                  <TextBlock x:Name="ExtendedSelectionCountText"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             Margin="0,4,0,0"
                             Text="Extended count"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14"
                      Margin="0,0,0,12">
                <StackPanel>
                  <Label Content="Multiple selection" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Multiple mode is simpler than Extended mode: every plain click toggles the clicked row. It is useful when additive selection should not depend on modifiers." />

                  <ListBox x:Name="MultipleListBox"
                           Height="176"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           SelectionMode="Multiple"
                           Margin="0,0,0,10" />

                  <TextBlock x:Name="MultipleSelectionSummaryText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Multiple summary"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14"
                      Margin="0,0,0,12">
                <StackPanel>
                  <Label Content="Templated items" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="ListBox inherits the full ItemsControl templating surface. This sample projects a richer work queue card for each item while the ListBox still owns selection, scrolling, and item containers." />

                  <ListBox x:Name="TemplatedListBox"
                           Height="286"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Top"
                           SelectedValuePath="Id"
                           Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="#15202B"
                                BorderBrush="#345165"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10"
                                Margin="0,0,0,4">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding Path=Title}"
                                         Foreground="#E7F2FA"
                                         FontWeight="SemiBold"
                                         TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Path=Summary}"
                                         Foreground="#BFD4E3"
                                         Margin="0,4,0,0"
                                         TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Path=Owner}"
                                         Foreground="#91AEC2"
                                         Margin="0,6,0,0"
                                         TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="#233746"
                                    BorderBrush="#567B93"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,4"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Top">
                              <TextBlock Text="{Binding Path=State}"
                                         Foreground="#D7EAF7"
                                         FontWeight="SemiBold"
                                         TextWrapping="Wrap" />
                            </Border>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <TextBlock x:Name="TemplatedSelectionSummaryText"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Templated summary"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="14">
                <StackPanel>
                  <Label Content="What this page covers" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Text="Single and multi-selection are both exercised here because selector bugs usually show up first in modifier-heavy flows." />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,6,0,0"
                             Text="Object-backed lists validate projection paths like DisplayMemberPath and SelectedValuePath without requiring a heavier control such as DataGrid." />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,6,0,0"
                             Text="Templated rows prove ListBox still behaves like an ItemsControl when item visuals become richer than plain text." />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,6,0,0"
                             Text="The virtualized backlog keeps scroll behavior visible so navigation and selection fixes can be checked on something closer to a production-sized list." />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






