<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.RadioButtonView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: RadioButton" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="RadioButton derives from ToggleButton but enforces mutually-exclusive selection. Sibling radio buttons share a group automatically, or you can bridge separate containers with GroupName. Checked and Unchecked bubble when the active choice changes, while Click still fires on every activation." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Visual states" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="The default style brightens the ring on hover, dims disabled controls, and renders the inner dot only for the checked item." />

                  <WrapPanel>
                    <RadioButton x:Name="NormalStateRadio" Content="Normal" Margin="0,0,16,8" />
                    <RadioButton x:Name="CheckedStateRadio" Content="Checked" Margin="0,0,16,8" />
                    <RadioButton x:Name="DisabledStateRadio" Content="Disabled" IsEnabled="False" Margin="0,0,16,8" />
                    <RadioButton x:Name="DisabledCheckedStateRadio" Content="Disabled + checked" IsEnabled="False" Margin="0,0,0,8" />
                  </WrapPanel>
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Sibling grouping" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Radio buttons under the same logical parent form an implicit group even without GroupName. Re-clicking the selected choice leaves it selected." />

                  <Border Background="{StaticResource DarkBgBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <RadioButton x:Name="DraftOptionRadio" Content="Draft" Margin="0,0,0,8" />
                      <RadioButton x:Name="ReviewOptionRadio" Content="Review" Margin="0,0,0,8" />
                      <RadioButton x:Name="PublishOptionRadio" Content="Publish" />
                    </StackPanel>
                  </Border>

                  <TextBlock x:Name="SiblingSelectionLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,10,0,0"
                             Text="Selected: Draft" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Sizing and spacing" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="RadioButton inherits typography, padding, alignment, width, and border properties from Button and Control. Use those to make dense or spacious option rows without changing its selection rules." />

                  <Border Background="{StaticResource DarkBgBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12">
                    <StackPanel>
                      <RadioButton x:Name="CompactDensityRadio"
                                   GroupName="DensityModes"
                                   Content="Compact"
                                   Padding="4,2,4,2"
                                   Margin="0,0,0,8" />
                      <RadioButton x:Name="DefaultDensityRadio"
                                   GroupName="DensityModes"
                                   Content="Default"
                                   Margin="0,0,0,8" />
                      <RadioButton x:Name="RoomyDensityRadio"
                                   GroupName="DensityModes"
                                   Content="Roomy"
                                   FontSize="18"
                                   Padding="16,10,16,10"
                                   HorizontalAlignment="Stretch" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="GroupName across containers" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Set the same GroupName to keep one shared selection even when radios live under different parents. The four choices below participate in a single cross-panel group." />

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource DarkBgBrush}"
                            BorderBrush="{StaticResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                      <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Left panel" Margin="0,0,0,8" />
                        <RadioButton x:Name="LowPriorityRadio" GroupName="PriorityGroup" Content="Low" Margin="0,0,0,8" />
                        <RadioButton x:Name="MediumPriorityRadio" GroupName="PriorityGroup" Content="Medium" />
                      </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource DarkBgBrush}"
                            BorderBrush="{StaticResource DarkBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12">
                      <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Right panel" Margin="0,0,0,8" />
                        <RadioButton x:Name="HighPriorityRadio" GroupName="PriorityGroup" Content="High" Margin="0,0,0,8" />
                        <RadioButton x:Name="CriticalPriorityRadio" GroupName="PriorityGroup" Content="Critical" />
                      </StackPanel>
                    </Border>
                  </Grid>

                  <TextBlock x:Name="CrossContainerSelectionLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,10,0,0"
                             Text="Shared selection: Medium" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Routed events and click" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Checked and Unchecked bubble only when selection changes. Click fires on every activation, including clicking the already-selected option." />

                  <Border Background="{StaticResource DarkBgBrush}"
                          BorderBrush="{StaticResource DarkBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          Margin="0,0,0,10">
                    <StackPanel>
                      <RadioButton x:Name="EventBrowseRadio" GroupName="EventModes" Content="Browse" Margin="0,0,0,8" />
                      <RadioButton x:Name="EventInspectRadio" GroupName="EventModes" Content="Inspect" Margin="0,0,0,8" />
                      <RadioButton x:Name="EventCalibrateRadio" GroupName="EventModes" Content="Calibrate" />
                    </StackPanel>
                  </Border>

                  <TextBlock x:Name="EventSelectionLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             Text="Selected mode: Browse" />
                  <TextBlock x:Name="ClickCountLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             Text="Click fired: 0" />
                  <TextBlock x:Name="CheckedCountLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             Text="Checked fired: 0" />
                  <TextBlock x:Name="UncheckedCountLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Text="Unchecked fired: 0" />
                </StackPanel>
              </Border>

            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






