<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="urn:inkkslinger-ui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="InkkSlinger.PasswordBoxView"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="urn:inkkslinger-ui ../Schemas/InkkSlinger.UI.xsd
                                 http://schemas.microsoft.com/winfx/2006/xaml ../Schemas/Xaml2006.xsd"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource DarkBgBrush}"
             BorderBrush="{StaticResource DarkBorderBrush}"
             BorderThickness="1"
             Padding="12">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource DarkElevatedBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
      <Label Content="Control Demo: PasswordBox" Foreground="{StaticResource TextPrimaryBrush}" />
    </Border>

    <Border Grid.Row="1" Background="{StaticResource DarkBgBrush}" BorderBrush="{StaticResource DarkBorderBrush}" BorderThickness="1" Padding="12">
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     Text="PasswordBox is a secure text editor with masking, reveal mode, clipboard policy, max-length coercion, multiline layout, scrollable viewports, custom styling, and a PasswordChanged event. This workbench keeps those behaviors live so you can type into the boxes, trigger state changes from buttons, and watch the diagnostics rail update." />

          <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Basic editing" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="This is the everyday single-line case: type directly, paste sample values, clear the buffer, and watch the stored password length and caret state update." />

                  <PasswordBox x:Name="BasicPasswordBox"
                               Width="320"
                               Margin="0,0,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="BasicSeedButton" Content="Seed token" Margin="0,0,8,8" />
                    <Button x:Name="BasicPhraseButton" Content="Seed passphrase" Margin="0,0,8,8" />
                    <Button x:Name="BasicClearButton" Content="Clear" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="BasicStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Password: empty" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Security and policy" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Toggle reveal mode, readonly, clipboard copy, and max-length limits. The long-value action intentionally overflows the current MaxLength so you can see coercion happen on assignment." />

                  <PasswordBox x:Name="PolicyPasswordBox"
                               Width="320"
                               Margin="0,0,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="PolicyToggleRevealButton" Content="Toggle reveal" Margin="0,0,8,8" />
                    <Button x:Name="PolicyToggleReadOnlyButton" Content="Toggle readonly" Margin="0,0,8,8" />
                    <Button x:Name="PolicyToggleClipboardButton" Content="Toggle clipboard" Margin="0,0,8,8" />
                    <Button x:Name="PolicyCycleMaxLengthButton" Content="Cycle MaxLength" Margin="0,0,8,8" />
                    <Button x:Name="PolicyOverflowButton" Content="Set long value" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="PolicyStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             TextWrapping="Wrap"
                             Text="Reveal: false | Readonly: false | Clipboard: false | MaxLength: 0" />
                  <TextBlock x:Name="PolicyValueLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Stored password: empty" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14">
                <StackPanel>
                  <Label Content="Layout and masking" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="PasswordBox also supports multiline content, wrapping modes, and configurable scrollbars. Load seeded samples, then cycle wrapping, scrollbar visibility, and mask characters to see how layout responds." />

                  <PasswordBox x:Name="LayoutPasswordBox"
                               Width="340"
                               Height="120"
                               Margin="0,0,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="LayoutLoadMultilineButton" Content="Load multiline" Margin="0,0,8,8" />
                    <Button x:Name="LayoutLoadSingleLineButton" Content="Load single line" Margin="0,0,8,8" />
                    <Button x:Name="LayoutCycleWrappingButton" Content="Cycle wrapping" Margin="0,0,8,8" />
                    <Button x:Name="LayoutCycleHorizontalButton" Content="Cycle h-scroll" Margin="0,0,8,8" />
                    <Button x:Name="LayoutCycleVerticalButton" Content="Cycle v-scroll" Margin="0,0,8,8" />
                    <Button x:Name="LayoutCycleMaskButton" Content="Cycle mask" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="LayoutStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Margin="0,0,0,4"
                             TextWrapping="Wrap"
                             Text="Wrapping: NoWrap | Horizontal: Auto | Vertical: Disabled | Mask: *" />
                  <TextBlock x:Name="LayoutMetricsLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="TextLength: 0 | Logical lines: 1 | Caret: 0" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="Styling playground" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="Foreground, background, border, caret, selection, padding, and border thickness are all per-instance. Use the palette actions below to restyle a live PasswordBox without changing its stored value." />

                  <PasswordBox x:Name="StyledPasswordBox"
                               Width="320"
                               Margin="0,0,0,10" />

                  <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="StyleWarmButton" Content="Warm palette" Margin="0,0,8,8" />
                    <Button x:Name="StyleCoolButton" Content="Cool palette" Margin="0,0,8,8" />
                    <Button x:Name="StyleSlateButton" Content="Slate palette" Margin="0,0,8,8" />
                    <Button x:Name="StyleThicknessButton" Content="Cycle border" Margin="0,0,8,8" />
                    <Button x:Name="StyleRevealButton" Content="Toggle reveal" Margin="0,0,0,8" />
                  </WrapPanel>

                  <TextBlock x:Name="StyleStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Palette: Warm | BorderThickness: 1 | Reveal: false" />
                </StackPanel>
              </Border>

              <Border Background="{StaticResource DarkElevatedBrush}"
                      BorderBrush="{StaticResource DarkBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="14"
                      Margin="0,0,0,10">
                <StackPanel>
                  <Label Content="State gallery" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                             TextWrapping="Wrap"
                             Margin="0,0,0,10"
                             Text="The gallery below highlights disabled visuals, a readonly field, and a revealed field that keeps the stored password intact while rendering plain text." />

                  <StackPanel Margin="0,0,0,10">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" Text="Disabled" />
                    <PasswordBox x:Name="DisabledPasswordBox"
                                 Width="320"
                                 IsEnabled="False"
                                 Margin="0,0,0,10" />

                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" Text="Readonly" />
                    <PasswordBox x:Name="ReadOnlyPasswordBox"
                                 Width="320"
                                 Margin="0,0,0,10" />

                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" Text="RevealPassword=True" />
                    <PasswordBox x:Name="RevealPasswordBox"
                                 Width="320" />
                  </StackPanel>

                  <TextBlock x:Name="GalleryStatusLabel"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             TextWrapping="Wrap"
                             Text="Disabled, readonly, and revealed variants are seeded below." />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>

          <Border Background="{StaticResource DarkElevatedBrush}"
                  BorderBrush="{StaticResource DarkBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="14"
                  Margin="0,10,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <Label Content="Event inspector" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Text="PasswordChanged fires whenever the stored password changes. The inspector also reads live caret, line-count, layout, policy, and performance counters from the same control so you can see how the internal editor reacts to edits." />

                <PasswordBox x:Name="InspectorPasswordBox"
                             Width="320"
                             Height="96"
                             Margin="0,0,0,10" />

                <WrapPanel>
                  <Button x:Name="InspectorSeedButton" Content="Seed sample" Margin="0,0,8,8" />
                  <Button x:Name="InspectorAppendButton" Content="Append suffix" Margin="0,0,8,8" />
                  <Button x:Name="InspectorClearButton" Content="Clear" Margin="0,0,8,8" />
                  <Button x:Name="InspectorRefreshMetricsButton" Content="Refresh metrics" Margin="0,0,8,8" />
                  <Button x:Name="InspectorResetMetricsButton" Content="Reset counters" Margin="0,0,0,8" />
                </WrapPanel>
              </StackPanel>

              <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="InspectorValueLabel" Grid.Row="0" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" Text="Stored password: empty" />
                <TextBlock x:Name="InspectorStateLabel" Grid.Row="1" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="TextLength: 0 | Caret: 0 | Lines: 1" />
                <TextBlock x:Name="InspectorPolicyLabel" Grid.Row="2" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Reveal: false | Readonly: false | Clipboard: false" />
                <TextBlock x:Name="InspectorLayoutLabel" Grid.Row="3" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="Wrapping: NoWrap | Horizontal: Auto | Vertical: Disabled" />
                <TextBlock x:Name="InspectorEventCountLabel" Grid.Row="4" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" Text="PasswordChanged fired: 0" />
                <TextBlock x:Name="InspectorLastChangeLabel" Grid.Row="5" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap" Text="Last change: none" />
                <TextBlock x:Name="InspectorPerfSummaryLabel" Grid.Row="6" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" Text="Commits: 0 | Immediate sync: 0 | Deferred sync: 0/0" />
                <TextBlock x:Name="InspectorLayoutPerfLabel" Grid.Row="7" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" TextWrapping="Wrap" Text="Layout cache hit/miss: 0/0 | Viewport builds: 0 | Full builds: 0" />
                <TextBlock x:Name="InspectorBufferMetricsLabel" Grid.Row="8" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Text="Buffer pieces: 0 | Materializations: 0 | Render avg/max ms: 0.000/0.000" />
              </Grid>
            </Grid>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>






